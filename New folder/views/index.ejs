<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Campus Marketplace — Buy &amp; Sell Student Goods</title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/index.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid"></div>
    <div class="hero-content">
      <h1>Buy &amp; sell <em>smarter</em><br>on campus</h1>
      <p class="hero-sub">Thousands of second-hand items — from textbooks and electronics to everyday essentials.</p>
      <div class="search-wrap">
        <select class="search-select" id="search-cat">
          <option value="">All categories</option>
          <option value="books">Books</option>
          <option value="electronics">Electronics</option>
          <option value="clothing">Clothing</option>
          <option value="furniture">Furniture</option>
          <option value="daily-needs">Daily needs</option>
          <option value="sports">Sports</option>
        </select>
        <input class="search-input" type="text" id="search-input" placeholder="Search for items...">
        <button class="search-btn" onclick="handleSearch()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          Search
        </button>
      </div>
      <div class="hero-stats">
        <div class="stat"><div class="stat-num">1,240+</div><div class="stat-label">Listings</div></div>
        <div class="stat"><div class="stat-num">850+</div><div class="stat-label">Students</div></div>
        <div class="stat"><div class="stat-num">3,500+</div><div class="stat-label">Deals</div></div>
        <div class="stat"><div class="stat-num">4.9★</div><div class="stat-label">Rating</div></div>
      </div>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="categories" id="categories">
    <div class="container">
      <div class="section-header fade-up">
        <div class="section-label">Categories</div>
        <h2>Find exactly what you need</h2>
        <p>From textbooks to laptops, everything is here</p>
      </div>
      <div class="cat-grid fade-up" id="cat-grid"></div>
    </div>
  </section>

  <!-- FEATURED -->
  <section class="featured" id="featured">
    <div class="container">
      <div class="section-header fade-up">
        <div class="section-label">Featured today</div>
        <h2>Latest listings</h2>
        <p>Posted in the last 24 hours</p>
      </div>
      <div class="filter-bar fade-up" id="filter-bar">
        <button class="filter-btn active" data-filter="all"        onclick="setFilter(this,'all')">
          <i data-lucide="layout-grid" width="14" height="14"></i> All
        </button>
        <button class="filter-btn" data-filter="books"       onclick="setFilter(this,'books')">
          <i data-lucide="book-open" width="14" height="14"></i> Books
        </button>
        <button class="filter-btn" data-filter="electronics" onclick="setFilter(this,'electronics')">
          <i data-lucide="monitor" width="14" height="14"></i> Electronics
        </button>
        <button class="filter-btn" data-filter="clothing"    onclick="setFilter(this,'clothing')">
          <i data-lucide="shirt" width="14" height="14"></i> Clothing
        </button>
        <button class="filter-btn" data-filter="daily-needs" onclick="setFilter(this,'daily-needs')">
          <i data-lucide="shopping-bag" width="14" height="14"></i> Daily needs
        </button>
        <button class="filter-btn" data-filter="sports"      onclick="setFilter(this,'sports')">
          <i data-lucide="dumbbell" width="14" height="14"></i> Sports
        </button>
      </div>
      <div class="products-grid" id="products-grid"></div>
      <div class="load-more-wrap fade-up">
        <button class="btn btn-secondary" style="padding:12px 32px;font-size:15px;" onclick="loadMore()">
          Load more listings
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="how-it-works" id="how">
    <div class="container">
      <div class="section-header fade-up">
        <div class="section-label">How it works</div>
        <h2>Simple — Fast — Reliable</h2>
      </div>
      <div class="steps-grid">
        <div class="step-card fade-up">
          <div class="step-icon"><i data-lucide="log-in"></i></div>
          <div class="step-title">Sign in with your email</div>
          <div class="step-desc">Use your Google account to verify your student identity.</div>
        </div>
        <div class="step-card fade-up" style="transition-delay:0.08s">
          <div class="step-icon"><i data-lucide="package-plus"></i></div>
          <div class="step-title">List your item</div>
          <div class="step-desc">Upload photos and AI automatically generates an attractive description.</div>
        </div>
        <div class="step-card fade-up" style="transition-delay:0.16s">
          <div class="step-icon"><i data-lucide="message-circle"></i></div>
          <div class="step-title">Chat directly</div>
          <div class="step-desc">Real-time chat with the seller, negotiate the price and arrange a meetup.</div>
        </div>
        <div class="step-card fade-up" style="transition-delay:0.24s">
          <div class="step-icon"><i data-lucide="handshake"></i></div>
          <div class="step-title">Safe exchange</div>
          <div class="step-desc">Meet in person on campus or arrange delivery.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BANNER -->
  <section class="trust-banner">
    <div class="container">
      <div class="trust-inner fade-up">
        <div class="trust-text">
          <h2>Get started today <i data-lucide="graduation-cap" style="display:inline-block;vertical-align:middle;width:28px;height:28px;"></i></h2>
          <p>Join a community of over 850 students buying and selling</p>
        </div>
        <div class="trust-actions">
          <% if (user) { %>
            <a href="/sell" class="btn-white">+ List an item</a>
            <a href="#featured" class="btn-outline-white">Browse listings</a>
          <% } else { %>
            <a href="/login" class="btn-white">Sign in now</a>
            <a href="#featured" class="btn-outline-white">Browse listings</a>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="container">
      <div class="footer-grid">
        <div>
          <div class="footer-brand">
            <i data-lucide="store" style="display:inline-block;vertical-align:middle;width:20px;height:20px;margin-right:6px;"></i>
            Campus Marketplace
          </div>
          <div class="footer-desc">A second-hand marketplace built exclusively for students.</div>
        </div>
        <div class="footer-col"><h4>Explore</h4><a href="#">Books</a><a href="#">Electronics</a><a href="#">Clothing</a></div>
        <div class="footer-col"><h4>Support</h4><a href="#">Help center</a><a href="#">Terms</a><a href="#">Privacy</a></div>
        <div class="footer-col"><h4>Connect</h4><a href="#">Facebook</a><a href="#">Instagram</a></div>
      </div>
    </div>
  </footer>

  <div id="toast-container"></div>

  <!-- Lucide Icons CDN -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>

  <script>
    // IS_AUTH từ server — không cần localStorage
    const IS_AUTH = <%= !!user %>;

    // Icon SVG strings cho JS-rendered content (category cards & product cards)
    const ICON_SVG = {
      books:        '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
      electronics:  '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
      clothing:     '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.38 3.46 16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z"/></svg>',
      furniture:    '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 9V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v3"/><path d="M2 11v5a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0v2H6v-2a2 2 0 0 0-4 0z"/><line x1="6" y1="18" x2="6" y2="22"/><line x1="18" y1="18" x2="18" y2="22"/></svg>',
      'daily-needs':'<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>',
      sports:       '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14.4 14.4 9.6 9.6"/><path d="M18.657 5.343A8 8 0 1 1 5.343 18.657 8 8 0 0 1 18.657 5.343z"/><path d="M5.343 5.343a8 8 0 0 1 11.314 11.314"/></svg>',
      gaming:       '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="12" x2="10" y2="12"/><line x1="8" y1="10" x2="8" y2="14"/><circle cx="15" cy="12" r=".5" fill="currentColor"/><circle cx="17.5" cy="10" r=".5" fill="currentColor"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59l-.9 7.2A4 4 0 0 0 5.77 20h.59a4 4 0 0 0 3.02-1.38l.86-1a2 2 0 0 1 1.52-.7h.5a2 2 0 0 1 1.52.7l.86 1A4 4 0 0 0 17.64 20h.59a4 4 0 0 0 3.97-4.21l-.9-7.2A4 4 0 0 0 17.32 5z"/></svg>',
      other:        '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>',
    };

    const CATEGORIES = [
      { icon: ICON_SVG.books,         name:'Books &amp; Textbooks',       slug:'books'       },
      { icon: ICON_SVG.electronics,   name:'Electronics &amp; Computers',  slug:'electronics' },
      { icon: ICON_SVG.clothing,      name:'Clothing &amp; Fashion',       slug:'clothing'    },
      { icon: ICON_SVG.furniture,     name:'Furniture &amp; Dorm',         slug:'furniture'   },
      { icon: ICON_SVG['daily-needs'],name:'Daily Essentials',             slug:'daily-needs' },
      { icon: ICON_SVG.sports,        name:'Sports &amp; Gym',             slug:'sports'      },
      { icon: ICON_SVG.gaming,        name:'Hobbies &amp; Entertainment',  slug:'gaming'      },
      { icon: ICON_SVG.other,         name:'Other',                        slug:'other'       },
    ];

    // Render categories
    document.getElementById('cat-grid').innerHTML = CATEGORIES.map(c =>
      '<div class="cat-card" onclick="filterByCategory(\'' + c.slug + '\')">' +
      '<div class="cat-icon">' + c.icon + '</div>' +
      '<div class="cat-name">' + c.name + '</div>' +
      '<div class="cat-count" style="opacity:0.6;">Loading...</div></div>'
    ).join('');

    // Product state
    window.ALL_PRODUCTS = [];
    window.currentFilteredProducts = [];
    window.displayCount = 12;
    const PER_PAGE = 12;

    async function fetchProducts() {
      try {
        const res      = await fetch('/api/products?limit=100', { credentials:'include' });
        const json     = await res.json();
        const products = json.data || [];
        window.ALL_PRODUCTS = products.map(p => ({
          id:        p._id,
          title:     p.title,
          category:  p.category,
          price:     p.price,
          condition: p.condition,
           image:     (p.images && p.images[0]) || null,
          icon:      ICON_SVG[p.category] || ICON_SVG.other,
          seller:    (p.seller && (p.seller.nickname || p.seller.name)) || 'Unknown',
          desc:      p.description || '',
        }));
        window.currentFilteredProducts = window.ALL_PRODUCTS;
        renderProducts(window.ALL_PRODUCTS);
        updateCategoryCounts();
      } catch (err) {
        console.error('Error loading products:', err);
        renderProducts([]);
      }
    }

    function updateCategoryCounts() {
      document.querySelectorAll('.cat-card').forEach((card, idx) => {
        const slug  = CATEGORIES[idx] && CATEGORIES[idx].slug;
        const count = window.ALL_PRODUCTS.filter(p => p.category === slug).length;
        const el    = card.querySelector('.cat-count');
        if (el) el.textContent = count > 0 ? count + '+ listings' : 'None yet';
      });
    }

    fetchProducts();

    // Fade-up animation
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.12 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    // Search
    document.getElementById('search-input').addEventListener('keydown', e => {
      if (e.key === 'Enter') handleSearch();
    });

    window.handleSearch = function () {
      const q   = document.getElementById('search-input').value.toLowerCase();
      const cat = document.getElementById('search-cat').value;
      let filtered = window.ALL_PRODUCTS;
      if (cat) filtered = filtered.filter(p => p.category === cat);
      if (q)   filtered = filtered.filter(p => p.title.toLowerCase().includes(q) || p.desc.toLowerCase().includes(q));
      window.currentFilteredProducts = filtered;
      window.displayCount = PER_PAGE;
      renderProducts(filtered);
      document.getElementById('featured').scrollIntoView({ behavior:'smooth' });
    };

    window.setFilter = function (btn, filter) {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filtered = filter === 'all' ? window.ALL_PRODUCTS : window.ALL_PRODUCTS.filter(p => p.category === filter);
      window.currentFilteredProducts = filtered;
      window.displayCount = PER_PAGE;
      renderProducts(filtered);
    };

    window.filterByCategory = function (slug) {
      document.getElementById('featured').scrollIntoView({ behavior:'smooth' });
      const btn = document.querySelector('[data-filter="' + slug + '"]');
      const filtered = window.ALL_PRODUCTS.filter(p => p.category === slug);
      window.currentFilteredProducts = filtered;
      window.displayCount = PER_PAGE;
      if (btn) window.setFilter(btn, slug);
      else renderProducts(filtered);
    };

    window.loadMore = function () {
      window.displayCount += PER_PAGE;
      renderProducts(window.currentFilteredProducts);
    };

    function formatPrice(p) {
      return new Intl.NumberFormat('vi-VN',{style:'currency',currency:'VND'}).format(p);
    }

    function conditionLabel(c) {
      const map = { new:'New', 'like-new':'Like new', good:'Good', fair:'Fair' };
      return '<span class="product-condition condition-' + c + '">' + (map[c]||c) + '</span>';
    }

    function renderProducts(products) {
      const grid = document.getElementById('products-grid');
      if (!products.length) {
        grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--text-3);">' +
          '<div style="display:flex;justify-content:center;margin-bottom:16px;opacity:0.4;">' +
          '<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>' +
          '</div><p style="font-size:16px;font-weight:600;">No listings found</p><p>Try a different keyword or browse another category.</p></div>';
        return;
      }
      const visible = products.slice(0, window.displayCount);
      const catLabel = { books:'Books', electronics:'Electronics', clothing:'Clothing', furniture:'Furniture', 'daily-needs':'Daily needs', sports:'Sports', gaming:'Gaming', other:'Other' };
      grid.innerHTML = visible.map(p =>
        '<div class="product-card" onclick="openProduct(\'' + p.id + '\')">' +
       '<div class="product-img-placeholder">' +
  (p.image
    ? '<img src="' + p.image + '" alt="' + p.title + '" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;">'
    : '<div style="display:flex;align-items:center;justify-content:center;height:100%;opacity:0.35;">' + p.icon.replace(/width="28" height="28"/, 'width="7vw" height="7vw"') + '</div>'
  ) +
'</div>' +
        '<div class="product-body">' +
        '<div class="product-category">' + (catLabel[p.category]||p.category) + '</div>' +
        conditionLabel(p.condition) +
        '<div class="product-name">' + p.title + '</div>' +
        '<div class="product-desc">' + p.desc + '</div>' +
        '<div class="product-footer">' +
        '<div class="product-price">' + formatPrice(p.price) + '</div>' +
        '<div class="product-seller"><div class="seller-avatar" style="background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;color:#fff;font-size:13px;font-weight:700;">' + p.seller[0] + '</div>' + p.seller + '</div>' +
        '</div></div></div>'
      ).join('');

      const loadMoreWrap = document.querySelector('.load-more-wrap');
      if (loadMoreWrap) loadMoreWrap.style.display = window.displayCount < products.length ? 'flex' : 'none';
    }

    window.openProduct = function (id) {
      if (!IS_AUTH) {
        const t = document.getElementById('toast-container');
        const el = document.createElement('div');
        el.className = 'toast error';
        el.textContent = 'Please sign in to view product details';
        t.appendChild(el);
        setTimeout(() => { window.location.href = '/login'; }, 1200);
        return;
      }
      window.location.href = '/products/' + id;
    };

    // Khởi tạo Lucide icons cho tất cả thẻ static trong HTML
    lucide.createIcons();
  </script>
</body>
</html>