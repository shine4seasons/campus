<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Authenticating — Campus Marketplace</title>
  <link rel="stylesheet" href="/css/main.css">
  <style>
    body { display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:100vh; font-family:inherit; background:#F7F8FC; }
    .logo { font-size:24px; font-weight:900; margin-bottom:24px; }
    .spinner { width:40px; height:40px; border:3px solid #E4E7F2; border-top-color:#1B5EFF; border-radius:50%; animation:spin 0.8s linear infinite; margin-bottom:16px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .msg  { color:#8890B0; font-size:14px; }
    .err-card { display:none; text-align:center; padding:24px; background:#fff; border-radius:16px; border:1px solid #FEE2E2; margin-top:16px; }
    .err-card p { color:#991B1B; margin-bottom:12px; }
    .err-card a { color:#1B5EFF; font-weight:700; text-decoration:none; }
  </style>
</head>
<body>
  <div class="logo">📚 Campus Marketplace</div>
  <div class="spinner" id="spinner"></div>
  <p class="msg" id="msg">Authenticating...</p>
  <div class="err-card" id="err-card">
    <p id="err-text">Login failed. Please try again.</p>
    <a href="/login">← Try again</a>
  </div>

  <script>
    // Server đã set httpOnly cookie và redirect về đây
    // Chỉ cần kiểm tra xem user có hợp lệ không rồi redirect
    (async () => {
      try {
        const res  = await fetch('/api/auth/me', { credentials: 'include' });
        const data = await res.json();

        if (!res.ok || !data.success) throw new Error('Not authenticated');

        const user = data.data;
        document.getElementById('msg').textContent = 'Welcome back, ' + user.name + '!';

        const redirectTo = sessionStorage.getItem('redirect_after_login') || '/';
        sessionStorage.removeItem('redirect_after_login');
        setTimeout(() => window.location.replace(redirectTo), 800);

      } catch (err) {
        document.getElementById('spinner').style.display = 'none';
        document.getElementById('msg').style.display     = 'none';
        document.getElementById('err-card').style.display = 'block';
      }
    })();
  </script>
</body>
</html>
