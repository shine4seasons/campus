<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile — Campus Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/profile.css">

</head>
<body>
  <%- include('partials/navbar') %>

  <div class="profile-wrap">
    <div class="profile-header">
      <h1>My Profile</h1>
    </div>

    <div class="profile-grid">

      <!-- ── LEFT: Avatar + Stats + Recent products ── -->
      <div style="display:flex;flex-direction:column;gap:20px;">

        <!-- Avatar card -->
        <div class="card avatar-card">
          <div class="avatar-wrap" id="avatar-wrap">
            <img
              src="<%= user.avatar || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) + '&background=E8F0FE&color=2563EB&size=200' %>"
              alt="<%= user.name %>"
              class="avatar-img"
              id="avatar-img"
            >
            <label class="avatar-change-btn" for="avatar-upload-input" title="Change avatar">
              📷
            </label>
            <input type="file" id="avatar-upload-input" accept="image/*">
          </div>
          <div class="avatar-name"><%= user.nickname || user.name %></div>
          <div class="avatar-email"><%= user.email %></div>
          <div class="avatar-hint">Avatar is synced from Google.<br>Or upload a custom one ↑</div>

          <div class="stats-mini">
            <div class="stat-mini">
              <div class="stat-mini-num">⭐ <%= (user.rating || 5).toFixed(1) %></div>
              <div class="stat-mini-lbl">Rating</div>
            </div>
            <div class="stat-mini">
              <div class="stat-mini-num"><%= user.totalSales || 0 %></div>
              <div class="stat-mini-lbl">Sold</div>
            </div>
            <div class="stat-mini">
              <div class="stat-mini-num"><%= user.ratingCount || 0 %></div>
              <div class="stat-mini-lbl">Reviews</div>
            </div>
          </div>
        </div>

        <!-- Recent products -->
        <div class="card">
          <div class="card-title">
            📦 My Listings
          </div>
          <% if (products && products.length > 0) { %>
            <div class="recent-products">
              <% const CAT_EMOJI = { books:'📚', electronics:'💻', clothing:'👕', furniture:'🛋️', 'daily-needs':'🧴', sports:'⚽', gaming:'🎮', other:'📦' }; %>
              <% products.slice(0, 4).forEach(function(p) { %>
                <div class="mini-row">
                  <div class="mini-thumb">
                    <% if (p.images && p.images[0]) { %>
                      <img src="<%= p.images[0] %>" alt="<%= p.title %>">
                    <% } else { %>
                      <%= CAT_EMOJI[p.category] || '📦' %>
                    <% } %>
                  </div>
                  <div style="flex:1;min-width:0;">
                    <div class="mini-title" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= p.title %></div>
                    <div class="mini-meta">
                      <span class="status-dot dot-<%= p.status %>"></span>
                      <%= p.status === 'active' ? 'Active' : p.status === 'sold' ? 'Sold' : 'Draft' %>
                      · 👁 <%= p.views || 0 %>
                    </div>
                  </div>
                  <div class="mini-price">
                    <%= new Intl.NumberFormat('vi-VN', { style:'currency', currency:'VND' }).format(p.price) %>
                  </div>
                </div>
              <% }) %>
            </div>
            <% if (products.length > 4) { %>
              <a href="/my-products" class="see-all">See all <%= products.length %> listings →</a>
            <% } %>
          <% } else { %>
            <div class="empty-mini">
              No listings yet.<br>
              <a href="/sell" style="color:#1B5EFF;font-weight:700;">Post your first item →</a>
            </div>
          <% } %>
        </div>

      </div>

      <!-- ── RIGHT: Edit form ── -->
      <div class="card form-section">
        <div class="card-title">✏️ Edit Profile</div>

        <!-- Read-only: từ Google -->
        <div class="form-row">
          <div class="form-group">
            <label>Full name <span style="color:#B0B6CC;font-weight:400;">(from Google)</span></label>
            <input type="text" value="<%= user.name %>" class="readonly" readonly>
          </div>
          <div class="form-group">
            <label>Email <span style="color:#B0B6CC;font-weight:400;">(from Google)</span></label>
            <input type="text" value="<%= user.email %>" class="readonly" readonly>
          </div>
        </div>

        <!-- Editable -->
        <div class="form-row">
          <div class="form-group">
            <label>Display name *</label>
            <input type="text" id="f-nickname"
              value="<%= user.nickname || '' %>"
              placeholder="E.g.: Alex Johnson" maxlength="40">
            <div class="form-hint">Name shown to other users</div>
          </div>
          <div class="form-group">
            <label>Phone number</label>
            <input type="tel" id="f-phone"
              value="<%= user.phone || '' %>"
              placeholder="(555) 123-4567" maxlength="15">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>University / College *</label>
            <input type="text" id="f-university"
              value="<%= user.university || '' %>"
              placeholder="E.g.: MIT" maxlength="80">
          </div>
          <div class="form-group">
            <label>Student ID</label>
            <input type="text" id="f-student-id"
              value="<%= user.studentId || '' %>"
              placeholder="20210001" maxlength="20">
            <div class="form-hint">Optional — helps verify you're a student</div>
          </div>
        </div>

        <div class="form-group">
          <label>Short bio</label>
          <textarea id="f-bio" rows="3" maxlength="200"
            placeholder="E.g.: 3rd-year CS student, buying/selling books and electronics..."><%= user.bio || '' %></textarea>
          <div class="form-hint" id="bio-count"><%= (user.bio || '').length %> / 200</div>
        </div>

        <div style="display:flex;align-items:center;gap:12px;padding-top:4px;">
          <button class="btn-save" id="btn-save" onclick="saveProfile()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Save changes
          </button>
          <span id="save-status" style="font-size:13px;color:#8890B0;"></span>
        </div>
      </div>

    </div>
  </div>

  <div id="toast-wrap"></div>

  <script>
    // ── Bio counter ──────────────────────────────────────
    document.getElementById('f-bio').addEventListener('input', function () {
      document.getElementById('bio-count').textContent = this.value.length + ' / 200';
    });

    // ── Save profile ─────────────────────────────────────
    window.saveProfile = async function () {
      const nickname   = document.getElementById('f-nickname').value.trim();
      const university = document.getElementById('f-university').value.trim();

      if (!nickname) {
        document.getElementById('f-nickname').style.borderColor = '#E84040';
        toast('Display name is required', 'err');
        return;
      }
      if (!university) {
        document.getElementById('f-university').style.borderColor = '#E84040';
        toast('University is required', 'err');
        return;
      }

      const btn = document.getElementById('btn-save');
      btn.disabled = true;
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" style="animation:spin 0.7s linear infinite"><circle cx="12" cy="12" r="10" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2"/><path d="M12 2a10 10 0 0 1 10 10" fill="none" stroke="#fff" stroke-width="2"/></svg> Saving...';

      try {
        const res = await fetch('/api/auth/profile', {
          method: 'PATCH',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            nickname,
            university,
            phone:      document.getElementById('f-phone').value.trim(),
            studentId:  document.getElementById('f-student-id').value.trim(),
            bio:        document.getElementById('f-bio').value.trim(),
            profileComplete: true,
          }),
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.message || 'Save failed');

        toast('Profile saved! ✓', 'ok');
        document.getElementById('save-status').textContent = 'Last saved: ' + new Date().toLocaleTimeString();

        // Cập nhật tên hiển thị ở avatar card
        document.querySelector('.avatar-name').textContent = data.data.nickname || data.data.name;

      } catch (err) {
        toast(err.message || 'Failed to save', 'err');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Save changes';
      }
    };

    // ── Avatar upload ─────────────────────────────────────
    document.getElementById('avatar-upload-input').addEventListener('change', async function () {
      const file = this.files[0];
      if (!file) return;
      if (file.size > 5 * 1024 * 1024) { toast('Image must be under 5MB', 'err'); return; }

      const wrap = document.getElementById('avatar-wrap');
      wrap.classList.add('avatar-uploading');

      try {
        const formData = new FormData();
        formData.append('image', file);

        const res  = await fetch('/api/upload/avatar', {
          method: 'POST',
          credentials: 'include',
          body: formData,
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.message || 'Upload failed');

        // Cập nhật avatar trên trang
        document.getElementById('avatar-img').src = data.url;

        // Lưu avatar mới vào profile
        await fetch('/api/auth/profile', {
          method: 'PATCH',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ avatar: data.url }),
        });

        toast('Avatar updated! ✓', 'ok');
      } catch (err) {
        toast(err.message || 'Upload failed', 'err');
      } finally {
        wrap.classList.remove('avatar-uploading');
        this.value = '';
      }
    });

    // ── Reset border on focus ─────────────────────────────
    ['f-nickname', 'f-university'].forEach(id => {
      document.getElementById(id).addEventListener('focus', function () {
        this.style.borderColor = '';
      });
    });

    function toast(msg, type) {
      const c = document.getElementById('toast-wrap');
      const t = document.createElement('div');
      t.className = 'toast ' + (type || 'ok');
      t.innerHTML = (type === 'err' ? '✕' : '✓') + ' ' + msg;
      c.appendChild(t);
      setTimeout(() => { t.style.opacity='0'; t.style.transition='opacity 0.3s'; setTimeout(()=>t.remove(), 300); }, 3000);
    }
  </script>
</body>
</html>
