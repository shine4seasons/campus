<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Orders — Campus Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link href="https://unpkg.com/maplibre-gl/dist/maplibre-gl.css" rel="stylesheet" />
<script src="https://unpkg.com/maplibre-gl/dist/maplibre-gl.js"></script>

</head>
<body>
  <%- include('partials/navbar') %>

  <div class="page-wrap">
    <div class="page-top">
      <h1>My Orders</h1>
      <p>Items you've purchased from other students</p>
    </div>

    <% if (!orders || orders.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">🛍️</div>
        <div class="empty-title">No orders yet</div>
        <div class="empty-sub">You haven't purchased anything yet. Browse listings to find something you like!</div>
        <a href="/" class="btn-browse">Browse listings →</a>
      </div>

    <% } else { %>
      <%
        const CAT_EMOJI = { books:'📚', electronics:'💻', clothing:'👕', furniture:'🛋️', 'daily-needs':'🧴', sports:'⚽', gaming:'🎮', other:'📦' };
        const fmt = n => new Intl.NumberFormat('vi-VN', { style:'currency', currency:'VND' }).format(n);
      %>
      <% orders.forEach(function(order, idx) { %>
        <%
          const seller    = order.seller || {};
          const sellerName = seller.nickname || seller.name || 'Unknown seller';
          const soldDate  = order.soldAt ? new Date(order.soldAt) : null;
          const hasLoc    = order.location && order.location.lat && order.location.lng;
          const hasAddr   = order.location && order.location.address;
        %>
        <div class="order-card" id="order-<%= idx %>">

          <!-- Header (clickable) -->
          <div class="order-header" onclick="toggleOrder(<%= idx %>)">
            <div class="order-thumb">
              <% if (order.images && order.images[0]) { %>
                <img src="<%= order.images[0] %>" alt="<%= order.title %>">
              <% } else { %>
                <%= CAT_EMOJI[order.category] || '📦' %>
              <% } %>
            </div>
            <div>
              <div class="order-title"><%= order.title %></div>
              <div class="order-meta">
                <span class="badge-completed">✓ Completed</span>
                <span>Seller: <strong><%= sellerName %></strong></span>
                <% if (soldDate) { %>
                  <span>📅 <%= soldDate.toLocaleDateString('en-US', { day:'numeric', month:'short', year:'numeric' }) %></span>
                <% } %>
              </div>
              <div style="font-size:15px;font-weight:900;color:#1B5EFF;margin-top:4px;">
                <%= fmt(order.price) %>
              </div>
            </div>
            <div class="order-chevron">⌄</div>
          </div>

          <!-- Expandable detail -->
          <div class="order-detail">

            <!-- LEFT: Status timeline + Seller -->
            <div>
              <div style="font-size:13px;font-weight:800;color:#0D0F1A;margin-bottom:14px;">Order status</div>
              <div class="timeline">
                <div class="tl-item done">
                  <div class="tl-line"></div>
                  <div class="tl-dot">✓</div>
                  <div class="tl-body">
                    <div class="tl-label">Order placed</div>
                    <div class="tl-sub">
                      <% if (soldDate) { %>
                        <%= soldDate.toLocaleString('en-US', { hour:'2-digit', minute:'2-digit', day:'numeric', month:'short' }) %>
                      <% } else { %>
                        Date not available
                      <% } %>
                    </div>
                  </div>
                </div>
                <div class="tl-item done">
                  <div class="tl-line"></div>
                  <div class="tl-dot">✓</div>
                  <div class="tl-body">
                    <div class="tl-label">Seller confirmed</div>
                    <div class="tl-sub">Item reserved for you</div>
                  </div>
                </div>
                <div class="tl-item done">
                  <div class="tl-line"></div>
                  <div class="tl-dot">✓</div>
                  <div class="tl-body">
                    <div class="tl-label">Meetup & handover</div>
                    <div class="tl-sub">
                      <% if (hasAddr) { %>
                        At: <%= order.location.address %>
                      <% } else { %>
                        Location arranged with seller
                      <% } %>
                    </div>
                  </div>
                </div>
                <div class="tl-item done">
                  <div class="tl-dot">✓</div>
                  <div class="tl-body">
                    <div class="tl-label">Completed</div>
                    <div class="tl-sub">Transaction finished successfully</div>
                  </div>
                </div>
              </div>

              <!-- Seller mini card -->
              <div style="font-size:13px;font-weight:800;color:#0D0F1A;margin:16px 0 8px;">Sold by</div>
              <div class="seller-mini">
                <div class="seller-mini-avatar">
                  <% if (seller.avatar) { %>
                    <img src="<%= seller.avatar %>" alt="<%= sellerName %>">
                  <% } else { %>
                    <%= (sellerName[0] || '?').toUpperCase() %>
                  <% } %>
                </div>
                <div>
                  <div class="seller-mini-name"><%= sellerName %></div>
                  <div class="seller-mini-sub">
                    <%= seller.university || '' %>
                    <% if (seller.phone) { %> · 📞 <%= seller.phone %><% } %>
                  </div>
                </div>
              </div>

              <!-- View product link -->
              <a href="/products/<%= order._id %>"
                style="display:inline-flex;align-items:center;gap:6px;margin-top:12px;font-size:13px;color:#1B5EFF;font-weight:700;text-decoration:none;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                View listing
              </a>
            </div>

            <!-- RIGHT: Map -->
            <div>
              <div style="font-size:13px;font-weight:800;color:#0D0F1A;margin-bottom:12px;">
                📍 Pickup location
              </div>

              <% if (hasLoc) { %>
                <div class="order-map-wrap">
                  <% if (typeof mapsKey !== 'undefined' && mapsKey) { %>
                    <div id="map-<%= order._id %>" style="height:200px;"></div>
                    <script>
                      const map_<%= order._id %> = new maplibregl.Map({
                        container: 'map-<%= order._id %>',
                        style: {
                          version: 8,
                          sources: {
                            'osm': {
                              type: 'raster',
                              tiles: ['https://tile.openstreetmap.org/{z}/{x}/{y}.png'],
                              tileSize: 256,
                              attribution: '© OpenStreetMap contributors'
                            }
                          },
                          layers: [{
                            id: 'osm',
                            type: 'raster',
                            source: 'osm'
                          }]
                        },
                        center: [<%= order.location.lng %>, <%= order.location.lat %>],
                        zoom: 15
                      });

                      new maplibregl.Marker()
                        .setLngLat([<%= order.location.lng %>, <%= order.location.lat %>])
                        .addTo(map_<%= order._id %>);
                    </script>
                  <% } else { %>
                    <iframe
                      src="https://www.openstreetmap.org/export/embed.html?bbox=<%= order.location.lng - 0.002 %>%2C<%= order.location.lat - 0.002 %>%2C<%= order.location.lng + 0.002 %>%2C<%= order.location.lat + 0.002 %>&layer=mapnik&marker=<%= order.location.lat %>%2C<%= order.location.lng %>"
                      loading="lazy">
                    </iframe>
                  <% } %>
                  <a class="map-open-link"
                    href="https://www.google.com/maps/search/?api=1&query=<%= order.location.lat %>,<%= order.location.lng %>"
                    target="_blank" rel="noopener">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    Open in Google Maps
                  </a>
                </div>
              <% } else if (hasAddr) { %>
                <div style="background:#F7F8FC;border:1.5px solid #E4E7F2;border-radius:12px;padding:16px;text-align:center;">
                  <div style="font-size:28px;margin-bottom:8px;">📍</div>
                  <div style="font-size:13px;font-weight:700;color:#0D0F1A;margin-bottom:4px;"><%= order.location.address %></div>
                  <a href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(order.location.address) %>"
                    target="_blank" rel="noopener"
                    style="font-size:12px;color:#1B5EFF;font-weight:700;text-decoration:none;">
                    Search on Google Maps →
                  </a>
                </div>
              <% } else { %>
                <div style="background:#F7F8FC;border:1.5px solid #E4E7F2;border-radius:12px;padding:24px;text-align:center;color:#8890B0;">
                  <div style="font-size:28px;margin-bottom:8px;">🤝</div>
                  <div style="font-size:13px;">Location was arranged directly with seller</div>
                </div>
              <% } %>

              <!-- Item summary box -->
              <div style="margin-top:14px;background:#F7F8FC;border-radius:12px;padding:12px 14px;">
                <div style="font-size:12px;color:#8890B0;margin-bottom:8px;font-weight:600;">ITEM SUMMARY</div>
                <div style="font-size:13px;font-weight:700;color:#0D0F1A;margin-bottom:4px;"><%= order.title %></div>
                <div style="display:flex;justify-content:space-between;font-size:13px;">
                  <span style="color:#8890B0;">Condition: <strong style="color:#3D4461;"><%= { new:'New', 'like-new':'Like new', good:'Good', fair:'Fair' }[order.condition] || order.condition %></strong></span>
                  <span style="font-weight:800;color:#1B5EFF;"><%= fmt(order.price) %></span>
                </div>
              </div>
            </div>

          </div><!-- /order-detail -->
        </div>
      <% }) %>
    <% } %>
  </div>

  <script>
    function toggleOrder(idx) {
      const card = document.getElementById('order-' + idx);
      card.classList.toggle('open');
    }
  </script>
</body>
</html>