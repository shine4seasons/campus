<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Listings — Campus Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/my-products.css">

</head>
<body>
  <%- include('partials/navbar') %>

  <div class="page-wrap">
    <div class="page-top">
      <h1>My Listings</h1>
      <a href="/sell" class="btn-new">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Post a new listing
      </a>
    </div>

    <%
      const _active = products.filter(p => p.status === 'active').length;
      const _sold   = products.filter(p => p.status === 'sold').length;
      const _views  = products.reduce((s, p) => s + (p.views || 0), 0);
      const CAT_EMOJI = { books:'📚', electronics:'💻', clothing:'👕', furniture:'🛋️', 'daily-needs':'🧴', sports:'⚽', gaming:'🎮', other:'📦' };
    %>

    <div class="stats-row">
      <div class="stat-card"><div class="stat-num"><%= products.length %></div><div class="stat-lbl">Total listings</div></div>
      <div class="stat-card"><div class="stat-num"><%= _active %></div><div class="stat-lbl">Active</div></div>
      <div class="stat-card"><div class="stat-num"><%= _sold %></div><div class="stat-lbl">Sold</div></div>
      <div class="stat-card"><div class="stat-num"><%= _views.toLocaleString('en-US') %></div><div class="stat-lbl">Views</div></div>
    </div>

    <div class="status-tabs" style="margin-bottom:20px;display:inline-flex;">
      <button class="status-tab active" data-status="all"    onclick="filterStatus('all',this)">All</button>
      <button class="status-tab"        data-status="active" onclick="filterStatus('active',this)">Active</button>
      <button class="status-tab"        data-status="sold"   onclick="filterStatus('sold',this)">Sold</button>
      <button class="status-tab"        data-status="hidden" onclick="filterStatus('hidden',this)">Draft</button>
    </div>

    <div class="products-list" id="products-list">
      <% if (products.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">📦</div>
          <div class="empty-title">You don't have any listings yet.</div>
          <div class="empty-sub">Post your first listing right now!</div>
          <a href="/sell" class="btn-new">+ Post a listing</a>
        </div>
      <% } else { %>
        <% products.forEach(p => { %>
          <div class="product-row" data-status="<%= p.status %>">
            <div class="row-thumb">
              <% if (p.images && p.images[0]) { %>
                <img src="<%= p.images[0] %>" alt="<%= p.title %>"
                  onerror="this.parentElement.textContent='<%= CAT_EMOJI[p.category] || '📦' %>'">
              <% } else { %>
                <%= CAT_EMOJI[p.category] || '📦' %>
              <% } %>
            </div>
            <div>
              <div class="row-title"><%= p.title %></div>
              <div class="row-meta">
                <span class="row-status <%= p.status === 'active' ? 's-active' : p.status === 'sold' ? 's-sold' : 's-hidden' %>">
                  <%= p.status === 'active' ? 'Active' : p.status === 'sold' ? 'Sold' : 'Draft' %>
                </span>
                <span>👁 <%= p.views || 0 %> views</span>
                <span>❤️ <%= p.interested || 0 %> interested</span>
                <span>📅 <%= new Date(p.createdAt).toLocaleDateString('en-US') %></span>
              </div>
              <div class="row-price">
                <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.price) %>
              </div>
            </div>
            <div class="row-actions">
              <button class="row-btn row-btn-edit"
                onclick="window.location.href='/sell?id=<%= p._id %>'">Edit</button>
              <button class="row-btn row-btn-del"
                onclick="deleteProduct('<%= p._id %>', this)">Delete</button>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <div id="toast-wrap"></div>

  <script>
    // ── Filter by status (DOM-based, no fetch needed) ──────
    window.filterStatus = function (status, btn) {
      document.querySelectorAll('.status-tab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');

      const rows = document.querySelectorAll('.product-row');
      rows.forEach(row => {
        row.style.display = (status === 'all' || row.dataset.status === status) ? '' : 'none';
      });

      const anyVisible = [...rows].some(r => r.style.display !== 'none');
      const list = document.getElementById('products-list');
      let empty = list.querySelector('.filter-empty');
      if (!anyVisible) {
        if (!empty) {
          empty = document.createElement('div');
          empty.className = 'empty-state filter-empty';
          const msgs = { active: 'No active listings.', sold: "You haven't sold anything yet.", hidden: 'No draft listings.' };
          empty.innerHTML = '<div class="empty-icon">📭</div><div class="empty-title">' + (msgs[status] || 'No listings.') + '</div>';
          list.appendChild(empty);
        }
      } else if (empty) {
        empty.remove();
      }
    };

    // ── Delete via API ─────────────────────────────────────
    window.deleteProduct = async function (pid, btn) {
      if (!confirm('Delete this listing? This action cannot be undone.')) return;
      btn.disabled = true;
      try {
        const res  = await fetch('/api/products/' + pid, { method: 'DELETE', credentials: 'include' });
        const data = await res.json();
        if (!res.ok) throw new Error(data.message || 'Delete failed');
        btn.closest('.product-row').remove();
        toast('Listing deleted', 'ok');
      } catch (err) {
        btn.disabled = false;
        toast(err.message, 'err');
      }
    };

    function toast(msg, type) {
      const c = document.getElementById('toast-wrap');
      const t = document.createElement('div');
      t.className = 'toast ' + (type || 'ok');
      t.innerHTML = (type === 'err' ? '✕' : '✓') + ' ' + msg;
      c.appendChild(t);
      setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; setTimeout(() => t.remove(), 300); }, 3000);
    }
  </script>
</body>
</html>
