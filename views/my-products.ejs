<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Listings — Campus Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
<%- include('partials/navbar') %>
<%- include('partials/sidebar') %>

<main class="main">
  <div class="content">

    <!-- ── SECTION: Listings ── -->
    <section class="section active" id="sListings" data-title="Listings" data-sub="Quản lý sản phẩm của bạn" data-cta="Đăng sản phẩm">
      <div class="tbl-wrap">
        <div class="tbl-toolbar">
          <div><div class="tbl-title">My products</div><div class="tbl-count">20 listings total</div></div>
          <div style="display:flex;align-items:center;gap:10px">
            <div class="filter-pills">
              <button class="f-pill on">All</button>
              <button class="f-pill">Active</button>
              <button class="f-pill">Sold</button>
              <button class="f-pill">Hidden</button>
            </div>
            <button class="btn btn-primary" onclick="window.location.href='/sell'">
              <svg viewBox="0 0 24 24" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Post product
            </button>
          </div>
        </div>
        <table>
          <thead>
            <tr><th>Product</th><th>Category</th><th>Price</th><th>Views</th><th>Interest</th><th>Posted</th><th>Status</th><th>Actions</th></tr>
          </thead>
          <tbody id="my-products-tbody">
            <tr><td colspan="8" class="empty">Loading your products...</td></tr>
          </tbody>
        </table>
        <div class="pagination">
          <span class="pg-info">Showing 1–5 / 20</span>
          <button class="pg-btn"><svg viewBox="0 0 24 24" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg></button>
          <button class="pg-btn active">1</button>
          <button class="pg-btn">2</button>
          <button class="pg-btn">3</button>
          <button class="pg-btn">4</button>
          <button class="pg-btn"><svg viewBox="0 0 24 24" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg></button>
        </div>
      </div>
    </section>

  </div><!-- /.content -->
</main>

<div id="toast-wrap"></div>

<script>window.INITIAL_SECTION = 'sListings';</script>
<%- include('partials/dashboard-scripts') %>
<script>
// Fetch seller's products and render into table
;(async function(){
  try{
    const res = await fetch('/api/products/my', { credentials: 'include' });
    const json = await res.json();
    const tbody = document.getElementById('my-products-tbody');
    if (!json.success) {
      tbody.innerHTML = '<tr><td colspan="8" class="empty">Failed to load products.</td></tr>';
      return;
    }
    const products = json.data || [];
    if (!products.length) {
      tbody.innerHTML = '<tr><td colspan="8" class="empty">You have no products yet.</td></tr>';
      return;
    }
    const rows = products.map(p => {
      const price = new Intl.NumberFormat('vi-VN', { style:'currency', currency:'VND' }).format(p.price || 0);
      const posted = new Date(p.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'2-digit' });
      const status = p.status || 'active';
      const badgeClass = status === 'active' ? 'badge-active' : (status === 'sold' ? 'badge-sold' : (status === 'hidden' ? 'badge-hidden' : 'badge-active'));
      return `
        <tr>
          <td><strong>${escapeHtml(p.title)}</strong></td>
          <td style="color:var(--t2)">${escapeHtml(p.category || '')}</td>
          <td>${price}</td>
          <td>${p.views || 0}</td>
          <td>${p.interested || 0}</td>
          <td style="color:var(--t2);font-size:12px">${posted}</td>
          <td><span class="badge ${badgeClass}">${status}</span></td>
          <td><div class="tbl-actions"><button class="act-btn primary" onclick="window.location='/sell?id=${p._id}'">Edit</button><button class="act-btn danger" onclick="toggleHide('${p._id}', '${status==='hidden' ? 'active' : 'hidden'}')">${status==='hidden'?'Unhide':'Hide'}</button></div></td>
        </tr>`;
    }).join('');
    tbody.innerHTML = rows;
    // update count
    const countEl = document.querySelector('.tbl-count');
    if (countEl) countEl.textContent = `${products.length} listings total`;
  }catch(err){
    const tbody = document.getElementById('my-products-tbody');
    tbody.innerHTML = '<tr><td colspan="8" class="empty">Failed to load products.</td></tr>';
    console.error('Failed to fetch my products:', err);
  }

  function escapeHtml(s){ return (s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]); }

  window.toggleHide = async function(productId, newStatus){
    try{
      const res = await fetch('/api/products/' + encodeURIComponent(productId), {
        method: 'PATCH',
        headers: {'Content-Type':'application/json'},
        credentials: 'include',
        body: JSON.stringify({ status: newStatus })
      });
      const j = await res.json();
      if (j.success) location.reload();
      else alert(j.message || 'Failed');
    }catch(e){ alert('Failed'); }
  };
})();
</script>
</body>
</html>
