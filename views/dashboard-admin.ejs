<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard — Campus Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

  <%- include('partials/navbar') %>
  <%- include('partials/sidebar') %>

  <main class="main">
    <div class="content">
<section class="section active" id="aDash">
      <div class="stat-grid">
        <div class="stat-card">
          <div class="stat-top">
            <div><div class="stat-label">Total users</div></div>
            <div class="stat-icon" style="background:#dbeafe;color:#2563eb">
              <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
          </div>
          <div class="stat-val">1,284</div>
          <div class="stat-delta delta-up">↑ 12% vs last month</div>
        </div>
        <div class="stat-card">
          <div class="stat-top">
            <div><div class="stat-label">Active listings</div></div>
            <div class="stat-icon" style="background:#dcfce7;color:#16a34a">
              <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg>
            </div>
          </div>
          <div class="stat-val">347</div>
          <div class="stat-delta delta-up">↑ +8 today</div>
        </div>
        <div class="stat-card">
          <div class="stat-top">
            <div><div class="stat-label">Orders this month</div></div>
            <div class="stat-icon" style="background:#fef3c7;color:#d97706">
              <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
          </div>
          <div class="stat-val">98</div>
          <div class="stat-delta delta-up">↑ 23% vs last month</div>
        </div>
        <div class="stat-card">
          <div class="stat-top">
            <div><div class="stat-label">GMV this month</div></div>
            <div class="stat-icon" style="background:#ede9fe;color:#7c3aed">
              <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6"/></svg>
            </div>
          </div>
          <div class="stat-val">42.6M ₫</div>
          <div class="stat-delta delta-dn">↓ -4% vs last month</div>
        </div>
      </div>

      <div class="charts-row">
        <div class="card">
          <div class="card-head">
            <div><div class="card-title">Revenue by month (GMV)</div><div class="card-sub">Total transactions, 2026</div></div>
            <a class="card-action" href="#">View details</a>
          </div>
          <div class="legend">
            <span class="leg-item"><span class="leg-dot" style="background:#2563eb"></span>GMV (₫M)</span>
            <span class="leg-item"><span class="leg-dot" style="background:#22c55e"></span>Orders</span>
          </div>
          <div style="position:relative;height:200px"><canvas id="cAdminGMV"></canvas></div>
        </div>
        <div class="card">
          <div class="card-head">
            <div><div class="card-title">Product categories</div><div class="card-sub">Listing distribution</div></div>
          </div>
          <div style="position:relative;height:170px;margin-bottom:12px"><canvas id="cAdminCat"></canvas></div>
          <div class="legend" style="flex-direction:column;gap:7px">
            <span class="leg-item"><span class="leg-dot" style="background:#2563eb"></span>Electronics 28%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#22c55e"></span>Books 24%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#f59e0b"></span>Clothing 19%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#8b5cf6"></span>Other 29%</span>
          </div>
        </div>
      </div>

      <div class="two-col">
        <div class="card">
          <div class="card-head"><div><div class="card-title">Top sellers</div><div class="card-sub">By revenue this month</div></div></div>
          <div class="list-item">
            <div class="li-rank gold">1</div>
            <div class="li-avatar" style="background:#fef3c7;color:#b45309">TN</div>
            <div class="li-info"><div class="li-name">Trần Ngọc</div><div class="li-sub">28 sales · ⭐ 4.9 · HUST</div></div>
            <div class="li-val">12.4M ₫</div>
          </div>
          <div class="list-item">
            <div class="li-rank silver">2</div>
            <div class="li-avatar" style="background:#dcfce7;color:#15803d">AL</div>
            <div class="li-info"><div class="li-name">An Lê</div><div class="li-sub">21 sales · ⭐ 4.8 · NEU</div></div>
            <div class="li-val">9.1M ₫</div>
          </div>
          <div class="list-item">
            <div class="li-rank bronze">3</div>
            <div class="li-avatar" style="background:#dbeafe;color:#1d4ed8">MH</div>
            <div class="li-info"><div class="li-name">Minh Hoa</div><div class="li-sub">17 sales · ⭐ 4.7 · VNU</div></div>
            <div class="li-val">7.8M ₫</div>
          </div>
          <div class="list-item">
            <div class="li-rank">4</div>
            <div class="li-avatar" style="background:#ede9fe;color:#6d28d9">PQ</div>
            <div class="li-info"><div class="li-name">Phúc Quang</div><div class="li-sub">15 sales · ⭐ 4.6 · HUST</div></div>
            <div class="li-val">6.2M ₫</div>
          </div>
          <div class="list-item">
            <div class="li-rank">5</div>
            <div class="li-avatar" style="background:#fee2e2;color:#b91c1c">LT</div>
            <div class="li-info"><div class="li-name">Lan Tú</div><div class="li-sub">12 sales · ⭐ 4.5 · FTU</div></div>
            <div class="li-val">4.9M ₫</div>
          </div>
        </div>
        <div class="card">
          <div class="card-head"><div><div class="card-title">Platform health</div><div class="card-sub">Operational metrics</div></div></div>
          <div class="prog-row">
            <div class="prog-item">
              <div class="prog-meta"><span class="prog-label">Order completion rate</span><span class="prog-val">84%</span></div>
              <div class="prog-bar"><div class="prog-fill" style="width:84%;background:#2563eb"></div></div>
            </div>
            <div class="prog-item">
              <div class="prog-meta"><span class="prog-label">Seller response</span><span class="prog-val">91%</span></div>
              <div class="prog-bar"><div class="prog-fill" style="width:91%;background:#22c55e"></div></div>
            </div>
            <div class="prog-item">
              <div class="prog-meta"><span class="prog-label">Profile complete</span><span class="prog-val">62%</span></div>
              <div class="prog-bar"><div class="prog-fill" style="width:62%;background:#f59e0b"></div></div>
            </div>
            <div class="prog-item">
              <div class="prog-meta"><span class="prog-label">Cancellation rate</span><span class="prog-val">8%</span></div>
              <div class="prog-bar"><div class="prog-fill" style="width:8%;background:#ef4444"></div></div>
            </div>
            <div class="prog-item">
              <div class="prog-meta"><span class="prog-label">Average rating</span><span class="prog-val">4.7/5</span></div>
              <div class="prog-bar"><div class="prog-fill" style="width:94%;background:#8b5cf6"></div></div>
            </div>
          </div>
        </div>
      </div>
    </section>
<section class="section" id="aAnalytics">
