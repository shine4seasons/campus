<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard — Campus Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link
    href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/rating.css">
</head>

<body>

  <%- include('partials/navbar') %>
    <%- include('partials/sidebar') %>

      <main class="main">
        <div class="content">
          <section class="section active" id="aDash">
            <div class="stat-grid">
              <div class="stat-card">
                <div class="stat-top">
                  <div>
                    <div class="stat-label">Total users</div>
                  </div>
                  <div class="stat-icon" style="background:#dbeafe;color:#2563eb">
                    <svg viewBox="0 0 24 24">
                      <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                      <circle cx="9" cy="7" r="4" />
                      <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
                    </svg>
                  </div>
                </div>
                <div class="stat-val">
                  <%= stats.totalUsers.value.toLocaleString() %>
                </div>
                <div class="stat-delta <%= stats.totalUsers.delta >= 0 ? 'delta-up' : 'delta-dn' %>">
                  <%= stats.totalUsers.delta>= 0 ? '↑' : '↓' %> <%= Math.abs(stats.totalUsers.delta) %>% vs last month
                </div>
              </div>
              <div class="stat-card">
                <div class="stat-top">
                  <div>
                    <div class="stat-label">Active products</div>
                  </div>
                  <div class="stat-icon" style="background:#dcfce7;color:#16a34a">
                    <svg viewBox="0 0 24 24">
                      <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                      <line x1="3" y1="6" x2="21" y2="6" />
                    </svg>
                  </div>
                </div>
                <div class="stat-val">
                  <%= stats.activeListings.value %>
                </div>
                <div class="stat-delta <%= stats.activeListings.delta >= 0 ? 'delta-up' : 'delta-dn' %>">
                  <%= stats.activeListings.delta>= 0 ? '↑' : '↓' %> +<%= Math.abs(stats.activeListings.delta) %> today
                </div>
              </div>
              <div class="stat-card">
                <div class="stat-top">
                  <div>
                    <div class="stat-label">Orders this month</div>
                  </div>
                  <div class="stat-icon" style="background:#fef3c7;color:#d97706">
                    <svg viewBox="0 0 24 24">
                      <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                      <polyline points="14 2 14 8 20 8" />
                    </svg>
                  </div>
                </div>
                <div class="stat-val">
                  <%= stats.ordersThisMonth.value %>
                </div>
                <div class="stat-delta <%= stats.ordersThisMonth.delta >= 0 ? 'delta-up' : 'delta-dn' %>">
                  <%= stats.ordersThisMonth.delta>= 0 ? '↑' : '↓' %> <%= Math.abs(stats.ordersThisMonth.delta) %>% vs
                      last month
                </div>
              </div>
              <div class="stat-card">
                <div class="stat-top">
                  <div>
                    <div class="stat-label">GMV this month</div>
                  </div>
                  <div class="stat-icon" style="background:#ede9fe;color:#7c3aed">
                    <svg viewBox="0 0 24 24">
                      <line x1="12" y1="1" x2="12" y2="23" />
                      <path d="M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6" />
                    </svg>
                  </div>
                </div>
                <div class="stat-val">
                  <%= stats.gmvThisMonth.value>= 1000000 ? (stats.gmvThisMonth.value / 1000000).toFixed(1) + 'M ₫' :
                    stats.gmvThisMonth.value.toLocaleString() + ' ₫' %>
                </div>
                <div class="stat-delta <%= stats.gmvThisMonth.delta >= 0 ? 'delta-up' : 'delta-dn' %>">
                  <%= stats.gmvThisMonth.delta>= 0 ? '↑' : '↓' %> <%= Math.abs(stats.gmvThisMonth.delta) %>% vs last
                      month
                </div>
              </div>
            </div>

            <div class="charts-row">
              <div class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Revenue by month (GMV)</div>
                    <div class="card-sub">Total transactions, 2026</div>
                  </div>
                  <a class="card-action" href="#">View details</a>
                </div>
                <div class="legend">
                  <span class="leg-item"><span class="leg-dot" style="background:#2563eb"></span>GMV (₫M)</span>
                  <span class="leg-item"><span class="leg-dot" style="background:#22c55e"></span>Orders</span>
                </div>
                <div style="position:relative;height:200px"><canvas id="cAdminGMV"></canvas></div>
              </div>
              <div class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Product categories</div>
                    <div class="card-sub">product distribution</div>
                  </div>
                </div>
                <div style="position:relative;height:170px;margin-bottom:12px"><canvas id="cAdminCat"></canvas></div>
                <div class="legend" style="flex-direction:column;gap:7px" id="adminCatLegend">
                  <% const catColors=['#2563eb', '#22c55e' , '#f59e0b' , '#8b5cf6' , '#06b6d4' , '#ec4899' , '#f97316'
                    , '#6366f1' ]; %>
                    <% CATEGORIES.forEach((cat, idx)=> { %>
                      <span class="leg-item"><span class="leg-dot"
                          style="background:<%= catColors[idx % catColors.length] %>"></span>
                        <%= cat.name.replace(/&amp;/g, '&' ) %>
                      </span>
                      <% }); %>
                </div>
              </div>
            </div>

            <div class="two-col">
              <div class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Top sellers</div>
                    <div class="card-sub">By revenue this month</div>
                  </div>
                </div>
                <% if (topSellers && topSellers.length> 0) { %>
                  <% topSellers.forEach((seller, index)=> { %>
                    <% const rank=index + 1; const rankClass=rank===1 ? 'gold' : rank===2 ? 'silver' : rank===3
                      ? 'bronze' : '' ; const
                      initials=seller.name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
                const revenueFormatted = seller.totalRevenue >= 1000000 ? (seller.totalRevenue / 1000000).toFixed(1) + ' M ₫' :
                      seller.totalRevenue.toLocaleString() + ' ₫' ; %>
                      <div class="list-item">
                        <div class="li-rank <%= rankClass %>">
                          <%= rank %>
                        </div>
                        <div class="li-avatar" style="background:#dbeafe;color:#2563eb">
                          <%= initials %>
                        </div>
                        <div class="li-info">
                          <a href="/user/<%= seller.sellerId %>" style="text-decoration:none;color:inherit;">
                            <div class="li-name" style="color:#1B5EFF;">
                              <%= seller.name %>
                            </div>
                            <div class="li-sub" style="display:flex;align-items:center;gap:4px;margin-top:2px">
                              <%= seller.totalOrders %> sales ·
                                <%- renderStars(seller.rating, 10) %>
                                  <span style="font-weight:600;font-size:11px">
                                    <%= seller.rating.toFixed(1) %>
                                  </span>
                                  · <%= seller.university || 'Unknown' %>
                            </div>
                          </a>
                        </div>
                        <div class="li-val">
                          <%= revenueFormatted %>
                        </div>
                      </div>
                      <% }); %>
                        <% } else { %>
                          <div class="list-item">
                            <div class="li-info">
                              <div class="li-name">No data available</div>
                            </div>
                          </div>
                          <% } %>
              </div>
              <div class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Platform health</div>
                    <div class="card-sub">Operational metrics</div>
                  </div>
                </div>
                <div class="prog-row">
                  <div class="prog-item">
                    <div class="prog-meta"><span class="prog-label">Order completion rate</span><span
                        class="prog-val">84%</span></div>
                    <div class="prog-bar">
                      <div class="prog-fill" style="width:84%;background:#2563eb"></div>
                    </div>
                  </div>
                  <div class="prog-item">
                    <div class="prog-meta"><span class="prog-label">Seller response</span><span
                        class="prog-val">91%</span></div>
                    <div class="prog-bar">
                      <div class="prog-fill" style="width:91%;background:#22c55e"></div>
                    </div>
                  </div>
                  <div class="prog-item">
                    <div class="prog-meta"><span class="prog-label">Profile complete</span><span
                        class="prog-val">62%</span></div>
                    <div class="prog-bar">
                      <div class="prog-fill" style="width:62%;background:#f59e0b"></div>
                    </div>
                  </div>
                  <div class="prog-item">
                    <div class="prog-meta"><span class="prog-label">Cancellation rate</span><span
                        class="prog-val">8%</span></div>
                    <div class="prog-bar">
                      <div class="prog-fill" style="width:8%;background:#ef4444"></div>
                    </div>
                  </div>
                  <div class="prog-item">
                    <div class="prog-meta"><span class="prog-label">Average rating</span><span
                        class="prog-val">4.7/5</span></div>
                    <div class="prog-bar">
                      <div class="prog-fill" style="width:94%;background:#8b5cf6"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </section>
          <section class="section" id="aAnalytics">
            <div class="stat-grid">
              <div class="stat-card">
                <div class="stat-top">
                  <div>
                    <div class="stat-label">New users (7d)</div>
                  </div>
                  <div class="stat-icon" style="background:#dcfce7;color:#16a34a"><svg viewBox="0 0 24 24">
                      <path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                      <circle cx="8.5" cy="7" r="4" />
                      <line x1="20" y1="8" x2="20" y2="14" />
                      <line x1="23" y1="11" x2="17" y2="11" />
                    </svg></div>
                </div>
                <div class="stat-val">86</div>
                <div class="stat-delta delta-up">↑ +14%</div>
              </div>
              <div class="stat-card">
                <div class="stat-top">
                  <div>
                    <div class="stat-label">Return rate</div>
                  </div>
                  <div class="stat-icon" style="background:#dbeafe;color:#2563eb"><svg viewBox="0 0 24 24">
                      <polyline points="17 1 21 5 17 9" />
                      <path d="M3 11V9a4 4 0 014-4h14M7 23l-4-4 4-4" />
                      <path d="M21 13v2a4 4 0 01-4 4H3" />
                    </svg></div>
                </div>
                <div class="stat-val">68%</div>
                <div class="stat-delta delta-up">↑ +3 pts</div>
              </div>
              <div class="stat-card">
                <div class="stat-top">
                  <div>
                    <div class="stat-label">Avg order value</div>
                  </div>
                  <div class="stat-icon" style="background:#fef3c7;color:#d97706"><svg viewBox="0 0 24 24">
                      <line x1="12" y1="1" x2="12" y2="23" />
                      <path d="M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6" />
                    </svg></div>
                </div>
                <div class="stat-val">435K ₫</div>
                <div class="stat-delta delta-dn">↓ -2%</div>
              </div>
              <div class="stat-card">
                <div class="stat-top">
                  <div>
                    <div class="stat-label">New products / day</div>
                  </div>
                  <div class="stat-icon" style="background:#ede9fe;color:#7c3aed"><svg viewBox="0 0 24 24">
                      <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                    </svg></div>
                </div>
                <div class="stat-val">11.4</div>
                <div class="stat-delta delta-up">↑ +6%</div>
              </div>
            </div>

            <div class="card" style="margin-bottom:22px">
              <div class="card-head">
                <div>
                  <div class="card-title">User growth — 2026</div>
                  <div class="card-sub">Cumulative registered accounts</div>
                </div>
              </div>
              <div style="position:relative;height:220px"><canvas id="cUserGrowth"></canvas></div>
            </div>

            <div class="two-col">
              <div class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Revenue by category</div>
                    <div class="card-sub">Accumulated GMV (₫M)</div>
                  </div>
                </div>
                <div style="position:relative;height:210px"><canvas id="cRevCat"></canvas></div>
              </div>
              <div class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Weekly orders</div>
                    <div class="card-sub">2026</div>
                  </div>
                </div>
                <div style="position:relative;height:210px"><canvas id="cWeekly"></canvas></div>
              </div>
            </div>

            <div class="three-col">
              <div class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Delivery method</div>
                    <div class="card-sub">Pickup vs Ship</div>
                  </div>
                </div>
                <div style="position:relative;height:150px;margin-bottom:10px"><canvas id="cDelivery"></canvas></div>
                <div class="legend" style="flex-direction:column;gap:6px" id="dlvLegend">
                  <span class="leg-item"><span class="leg-dot" style="background:#2563eb"></span>Pickup — 63%</span>
                  <span class="leg-item"><span class="leg-dot" style="background:#22c55e"></span>Ship — 37%</span>
                </div>
              </div>
              <div class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Payment methods</div>
                    <div class="card-sub">Cash vs Card</div>
                  </div>
                </div>
                <div style="position:relative;height:150px;margin-bottom:10px"><canvas id="cPayment"></canvas></div>
                <div class="legend" style="flex-direction:column;gap:6px" id="payLegend">
                  <span class="leg-item"><span class="leg-dot" style="background:#f59e0b"></span>Cash — 71%</span>
                  <span class="leg-item"><span class="leg-dot" style="background:#8b5cf6"></span>Card — 29%</span>
                </div>
              </div>
              <div class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Order status</div>
                    <div class="card-sub">Distribution this month</div>
                  </div>
                </div>
                <div style="position:relative;height:150px;margin-bottom:10px"><canvas id="cOrderStatus"></canvas></div>
                <div class="legend" style="flex-direction:column;gap:6px" id="orderStsLegend">
                  <span class="leg-item"><span class="leg-dot" style="background:#22c55e"></span>Completed — 62%</span>
                  <span class="leg-item"><span class="leg-dot" style="background:#2563eb"></span>Confirmed — 23%</span>
                  <span class="leg-item"><span class="leg-dot" style="background:#f59e0b"></span>Pending — 7%</span>
                  <span class="leg-item"><span class="leg-dot" style="background:#ef4444"></span>Cancelled — 8%</span>
                </div>
              </div>
            </div>
          </section>
          <section class="section" id="aUsers">
            <div class="tbl-wrap">
              <div class="tbl-toolbar">
                <div>
                  <div class="tbl-title">All users</div>
                  <div class="tbl-count">1,284 accounts</div>
                </div>
                <div style="display:flex;align-items:center;gap:10px">
                  <div class="filter-pills">
                    <button class="f-pill on">All</button>
                    <button class="f-pill">Active</button>
                    <button class="f-pill">Banned</button>
                    <button class="f-pill">New (7d)</button>
                  </div>
                  <button class="btn btn-primary" onclick="showToast('Invite user','ok')">
                    <svg viewBox="0 0 24 24" stroke-width="2.5">
                      <line x1="12" y1="5" x2="12" y2="19" />
                      <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                    Invite user
                  </button>
                </div>
              </div>
              <div class="tbl-search">
                <svg viewBox="0 0 24 24" stroke-width="2">
                  <circle cx="11" cy="11" r="8" />
                  <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input type="text" placeholder="Search by name, email, university...">
              </div>
              <table>
                <thead>
                  <tr>
                    <th>User</th>
                    <th>University</th>
                    <th>Joined</th>
                    <th>Sold</th>
                    <th>Purchased</th>
                    <th>Rating</th>
                    <th>Role</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="usersTableBody">
                  <tr>
                    <td colspan="9" style="text-align:center;color:var(--t2);padding:24px">Loading...</td>
                  </tr>
                </tbody>
              </table>
              <div class="pagination"></div>
            </div>
          </section>
          <section class="section" id="aProducts">
            <div class="tbl-wrap">
              <div class="tbl-toolbar">
                <div>
                  <div class="tbl-title">All products</div>
                  <div class="tbl-count">
                    <%= (stats.totalListings?.value || 0).toLocaleString() %> products
                  </div>
                </div>
                <div class="filter-pills">
                  <button class="f-pill on" data-status="">All</button>
                  <button class="f-pill" data-status="active">Active</button>
                  <button class="f-pill" data-status="sold">Sold</button>
                  <button class="f-pill" data-status="hidden">Hidden</button>
                  <button class="f-pill" data-status="reported" style="border-color:#fca5a5;color:#ef4444">Reported
                    (3)</button>
                </div>
              </div>
              <div class="tbl-search">
                <svg viewBox="0 0 24 24" stroke-width="2">
                  <circle cx="11" cy="11" r="8" />
                  <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input type="text" placeholder="Search by product name, seller...">
              </div>
              <table>
                <thead>
                  <tr>
                    <th>Product</th>
                    <th>Seller</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Views</th>
                    <th>Interest</th>
                    <th>Status</th>
                    <th>Posted</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td><strong>Casio FX-580VNX</strong></td>
                    <td style="color:var(--t2)">Trần Ngọc</td>
                    <td style="color:var(--t2)">Electronics</td>
                    <td>320,000 ₫</td>
                    <td>124</td>
                    <td>8</td>
                    <td><span class="badge badge-active">Active</span></td>
                    <td style="color:var(--t2);font-size:12px">02/04/2026</td>
                    <td>
                      <div class="tbl-actions"><button class="act-btn primary">View</button><button
                          class="act-btn danger" onclick="showToast('Product hidden','ok')">Hide</button></div>
                    </td>
                  </tr>
                  <tr>
                    <td><strong>Macroeconomics Textbook</strong></td>
                    <td style="color:var(--t2)">An Lê</td>
                    <td style="color:var(--t2)">Books</td>
                    <td>80,000 ₫</td>
                    <td>88</td>
                    <td>4</td>
                    <td><span class="badge badge-active">Active</span></td>
                    <td style="color:var(--t2);font-size:12px">28/03/2026</td>
                    <td>
                      <div class="tbl-actions"><button class="act-btn primary">View</button><button
                          class="act-btn danger">Hide</button></div>
                    </td>
                  </tr>
                  <tr>
                    <td><strong>HUST Hoodie 2024</strong></td>
                    <td style="color:var(--t2)">Minh Hoa</td>
                    <td style="color:var(--t2)">Clothing</td>
                    <td>250,000 ₫</td>
                    <td>210</td>
                    <td>18</td>
                    <td><span class="badge badge-sold">Sold</span></td>
                    <td style="color:var(--t2);font-size:12px">15/03/2026</td>
                    <td>
                      <div class="tbl-actions"><button class="act-btn">View</button></div>
                    </td>
                  </tr>
                  <tr style="background:#fff7ed">
                    <td><strong>Laptop Dell XPS 13 (2024)</strong></td>
                    <td style="color:var(--t2)">Phúc Quang</td>
                    <td style="color:var(--t2)">Electronics</td>
                    <td>18,500,000 ₫</td>
                    <td>543</td>
                    <td>32</td>
                    <td><span class="badge badge-reported">Reported</span></td>
                    <td style="color:var(--t2);font-size:12px">10/03/2026</td>
                    <td>
                      <div class="tbl-actions"><button class="act-btn primary">Review</button><button
                          class="act-btn danger" onclick="showToast('Product deleted','ok')">Delete</button></div>
                    </td>
                  </tr>
                  <tr>
                    <td><strong>Memory Foam Pillow</strong></td>
                    <td style="color:var(--t2)">Bảo Khánh</td>
                    <td style="color:var(--t2)">Furniture</td>
                    <td>450,000 ₫</td>
                    <td>67</td>
                    <td>5</td>
                    <td><span class="badge badge-hidden">Hidden</span></td>
                    <td style="color:var(--t2);font-size:12px">01/03/2026</td>
                    <td>
                      <div class="tbl-actions"><button class="act-btn success"
                          onclick="showToast('Product restored','ok')">Restore</button></div>
                    </td>
                  </tr>
                </tbody>
              </table>
              <div class="pagination"></div>
            </div>
          </section>
          <section class="section" id="aOrders">
            <div class="status-counters">
              <div class="status-count-card" style="border-top-color:#d97706">
                <div class="sc-label">Pending confirmation</div>
                <div class="sc-val" style="color:#d97706">14</div>
              </div>
              <div class="status-count-card" style="border-top-color:#2563eb">
                <div class="sc-label">Confirmed</div>
                <div class="sc-val" style="color:#2563eb">23</div>
              </div>
              <div class="status-count-card" style="border-top-color:#16a34a">
                <div class="sc-label">Completed</div>
                <div class="sc-val" style="color:#16a34a">61</div>
              </div>
              <div class="status-count-card" style="border-top-color:#dc2626">
                <div class="sc-label">Cancelled</div>
                <div class="sc-val" style="color:#dc2626">8</div>
              </div>
            </div>
            <div class="tbl-wrap">
              <div class="tbl-toolbar">
                <div>
                  <div class="tbl-title">All orders</div>
                  <div class="tbl-count">106 orders</div>
                </div>
                <div class="filter-pills">
                  <button class="f-pill on">All</button>
                  <button class="f-pill">Pending</button>
                  <button class="f-pill">Confirmed</button>
                  <button class="f-pill">Completed</button>
                  <button class="f-pill">Cancelled</button>
                </div>
              </div>
              <table>
                <thead>
                  <tr>
                    <th>Order ID</th>
                    <th>Product</th>
                    <th>Buyer</th>
                    <th>Seller</th>
                    <th>Price</th>
                    <th>Delivery</th>
                    <th>Payment</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody id="ordersTableBody">
                  <tr>
                    <td colspan="8" style="text-align:center;color:var(--t2);padding:24px">Loading...</td>
                  </tr>
                </tbody>
              </table>
              <div class="pagination"></div>
            </div>
          </section>
          <section class="section" id="aReports">
            <div class="alert-box alert-warn" style="margin-bottom:18px">
              <svg viewBox="0 0 24 24" stroke-width="2">
                <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                <line x1="12" y1="9" x2="12" y2="13" />
                <line x1="12" y1="17" x2="12.01" y2="17" />
              </svg>
              <div class="alert-box-text">There are 3 reported items awaiting review. Please review and take action
                promptly.</div>
            </div>
            <div class="tbl-wrap">
              <div class="tbl-toolbar">
                <div>
                  <div class="tbl-title">Reported content</div>
                  <div class="tbl-count" id="reports-total">0 items</div>
                </div>
                <div class="filter-pills">
                  <button class="f-pill on" data-filter="all">All</button>
                  <button class="f-pill" data-filter="pending">Pending</button>
                  <button class="f-pill" data-filter="under-review">Under Review</button>
                  <button class="f-pill" data-filter="resolved">Resolved</button>
                </div>
              </div>
              <table>
                <thead>
                  <tr>
                    <th>Type</th>
                    <th>Target</th>
                    <th>Reporter</th>
                    <th>Reason</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="reportsTableBody">
                  <tr>
                    <td colspan="7" style="text-align:center;color:var(--t2);padding:24px">Loading...</td>
                  </tr>
                </tbody>
              </table>
              <div class="pagination"></div>
            </div>
          </section>
          <section class="section" id="aSettings">
            <div class="two-col">
              <div class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Platform settings</div>
                    <div class="card-sub">General settings</div>
                  </div>
                </div>
                <div class="form-grid">
                  <div class="form-group"><label class="form-label">Platform name</label><input class="form-input"
                      value="Campus Marketplace"></div>
                  <div class="form-row">
                    <div class="form-group"><label class="form-label">Service fee (%)</label><input class="form-input"
                        type="number" value="0"></div>
                    <div class="form-group"><label class="form-label">Image/product limit</label><input
                        class="form-input" type="number" value="5"></div>
                  </div>
                  <div class="form-group"><label class="form-label">Support email</label><input class="form-input"
                      type="email" value="support@campusmkt.vn"></div>
                  <div class="form-group"><label class="form-label">System notifications</label><textarea
                      class="form-textarea" placeholder="Send announcement to all users..."></textarea></div>
                  <button class="btn btn-primary" style="align-self:flex-start"
                    onclick="if(window.saveAdminSettings) window.saveAdminSettings(); else showToast('Settings saved','ok')">Save
                    changes</button>
                </div>
              </div>
              <div>
                <div class="card" style="margin-bottom:16px">
                  <div class="card-head">
                    <div>
                      <div class="card-title">Category management</div>
                      <div class="card-sub"><span id="adminCatCount">
                          <%= CATEGORIES.length %>
                        </span> categories available</div>
                    </div><button class="act-btn primary"
                      onclick="showToast('Category add feature in development','info')">+ Add</button>
                  </div>
                  <div style="display:flex;flex-direction:column;gap:2px" id="adminCategoriesList">
                    <% CATEGORIES.forEach((cat, idx)=> { %>
                      <div class="list-item">
                        <div class="li-info">
                          <div class="li-name">
                            <%= cat.name.replace(/&amp;/g, '&' ) %>
                          </div>
                          <div class="li-sub">Category ID: <%= cat.slug %>
                          </div>
                        </div>
                        <button class="act-btn" onclick="showToast('Edit feature in development', 'info')">Edit</button>
                      </div>
                      <% }); %>
                  </div>
                </div>
                <div class="card">
                  <div class="card-head">
                    <div>
                      <div class="card-title">System statistics</div>
                    </div>
                  </div>
                  <div style="display:flex;flex-direction:column;gap:8px;font-size:13px" id="adminSysStats">
                    <div style="display:flex;justify-content:space-between"><span style="color:var(--t2)">Database
                        size</span><span style="font-weight:600">Calculating...</span></div>
                    <div style="margin-top:20px;padding-top:16px;border-top:1px solid var(--border)">
                      <button class="btn btn-outline" style="width:100%;justify-content:center;font-size:12px;"
                        onclick="syncSellerRatings()">
                        <svg viewBox="0 0 24 24" style="width:14px;height:14px;margin-right:6px" fill="none"
                          stroke="currentColor" stroke-width="2.5">
                          <path
                            d="M21.5 2v6h-6M2.5 22v-6h6M2 12c0-4.4 3.6-8 8-8 3.3 0 6.2 2 7.4 4.9M22 12c0 4.4-3.6 8-8 8-3.3 0-6.2-2-7.4-4.9" />
                        </svg>
                        Sync Seller Ratings
                      </button>
                      <p style="font-size:10px;color:var(--t3);margin-top:8px;text-align:center;line-height:1.4">
                        Recalculates all seller ratings based on their product reviews. Use this after data imports.</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </section>
        </div>
      </main>

      <div id="toast-wrap"></div>


      <script>window.INITIAL_SECTION = "<%= initialSection || '' %>";</script>
      <script src="/js/rating.js"></script>
      <%- include('partials/dashboard-scripts') %>

        <script>
          // ── Admin Users Table (dynamic) ─────────────────────────────────
          (function () {
            const AVATAR_COLORS = [
              { bg: '#dbeafe', fg: '#1d4ed8' }, { bg: '#dcfce7', fg: '#15803d' },
              { bg: '#fef3c7', fg: '#b45309' }, { bg: '#ede9fe', fg: '#6d28d9' },
              { bg: '#fee2e2', fg: '#b91c1c' }, { bg: '#ccfbf1', fg: '#0f766e' }
            ];

            function getAvatarColor(str) {
              let h = 0;
              for (let i = 0; i < str.length; i++) h = str.charCodeAt(i) + ((h << 5) - h);
              return AVATAR_COLORS[Math.abs(h) % AVATAR_COLORS.length];
            }

            function getInitials(name) {
              return (name || '?').split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
            }

            function roleBadge(user) {
              if (user.role === 'admin') return '<span class="badge badge-admin">Admin</span>';
              if (user.banned) return '<span class="badge badge-cancelled">Banned</span>';
              return '<span class="badge badge-active">User</span>';
            }

            // Expose loadUsers globally so it can be called by initAdminData
            window.loadUsers = loadUsers;

            function renderUsersTable(users) {
              const tbody = document.getElementById('usersTableBody');
              if (!tbody) return;
              if (!users || users.length === 0) {
                tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;color:var(--t2);padding:24px">No users found</td></tr>';
                return;
              }
              tbody.innerHTML = users.map(u => {
                const c = getAvatarColor(u._id);
                const initials = getInitials(u.nickname || u.name);
                const joined = u.createdAt ? new Date(u.createdAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) : '—';
                const rating = u.rating ? `<div style="display:flex;align-items:center;gap:4px">
          ${renderStars(u.rating, 10)}
          <span style="font-size:11px;font-weight:700">${Number(u.rating).toFixed(1)}</span>
        </div>` : '<span style="color:var(--t3)">—</span>';
                const actions = u.banned
                  ? `<button class="act-btn" onclick="window.location.href='/user/${u._id}'">View</button>
             <button class="act-btn success" onclick="adminToggleBan('${u._id}', false, this)">Unban</button>`
                  : u.role === 'admin'
                    ? `<button class="act-btn primary" onclick="window.location.href='/user/${u._id}'">View</button>
             <button class="act-btn" onclick="showToast('Admin privileges revoked','ok')">Revoke</button>`
                    : `<button class="act-btn primary" onclick="window.location.href='/user/${u._id}'">View</button>
             <button class="act-btn danger" onclick="adminToggleBan('${u._id}', true, this)">Ban</button>`;
                return `<tr>
          <td><a href="/user/${u._id}" style="text-decoration:none;color:inherit;"><div class="user-cell">
            <div class="uc-avatar" style="background:${c.bg};color:${c.fg}">${initials}</div>
            <div style="min-width: 0;"><div class="uc-name" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:180px;">${u.nickname || u.name || '—'}</div><div class="uc-sub" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:180px;">${u.email || ''}</div></div>
          </div></a></td>
          <td style="color:var(--t2)">${u.university || '—'}</td>
          <td style="color:var(--t2)">${joined}</td>
          <td><strong>${u.totalSales || 0}</strong></td>
          <td>${u.totalPurchases || 0}</td>
          <td>${rating}</td>
          <td>${roleBadge(u)}</td>
          <td><div class="tbl-actions">${actions}</div></td>
        </tr>`;
              }).join('');
            }

            async function adminToggleBan(userId, banned, btn) {
              try {
                const res = await fetch(`/api/admin/users/${userId}/ban`, {
                  method: 'PATCH',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ banned })
                });
                if (!res.ok) throw new Error();
                showToast(banned ? 'Account banned' : 'Account unbanned', 'ok');
                loadUsers();
              } catch {
                showToast('Action failed', 'error');
              }
            }

            window.adminToggleBan = adminToggleBan;

            // Search + filter state
            let currentFilter = '';
            let searchTimeout;

            // Wire up filter pills
            document.querySelectorAll('#aUsers .f-pill').forEach(pill => {
              pill.addEventListener('click', () => {
                document.querySelectorAll('#aUsers .f-pill').forEach(p => p.classList.remove('on'));
                pill.classList.add('on');
                const txt = pill.textContent.trim().toLowerCase();
                currentFilter = txt === 'all' ? '' : txt === 'new (7d)' ? 'new' : txt;
                loadUsers();
              });
            });

            // Wire up search
            const searchInput = document.querySelector('#aUsers .tbl-search input');
            if (searchInput) {
              searchInput.addEventListener('input', () => {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(loadUsers, 300);
              });
            }

            async function loadUsers(page = 1) {
              const tbody = document.getElementById('usersTableBody');
              if (!tbody) return;
              tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--t2);padding:24px">Loading...</td></tr>';

              const q = searchInput ? searchInput.value.trim() : '';
              const params = new URLSearchParams({ limit: 20, page });
              if (q) params.set('q', q);
              if (currentFilter && currentFilter !== 'new') params.set('status', currentFilter);

              try {
                const res = await fetch(`/api/admin/users?${params}`);
                const json = await res.json();
                if (json.success) {
                  renderUsersTable(json.data);
                  if (typeof renderPagination === 'function') {
                    renderPagination('#aUsers .pagination', json.pagination, 'loadUsers');
                  }
                } else {
                  tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;color:var(--danger);padding:24px">Failed to load users</td></tr>';
                }
              } catch {
                tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;color:var(--danger);padding:24px">Network error</td></tr>';
              }
            }

            // Load on section activation (MutationObserver handled via dash-scripts initAdminData)
            // No redundant calls here
          })();

          // ── Admin Orders Table (dynamic) ─────────────────────────────────
          (function () {
            const statusBadges = {
              'pending': 'badge-pending',
              'confirmed': 'badge-confirmed',
              'completed': 'badge-completed',
              'cancelled': 'badge-cancelled'
            };

            function getStatusBadge(status) {
              const badge = statusBadges[status] || 'badge-pending';
              return `<span class="badge ${badge}">${status.charAt(0).toUpperCase() + status.slice(1)}</span>`;
            }

            function renderOrdersTable(orders) {
              const tbody = document.getElementById('ordersTableBody');
              if (!tbody) return;
              if (!orders || orders.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--t2);padding:24px">No orders found</td></tr>';
                return;
              }
              tbody.innerHTML = orders.map(order => {
                const orderId = order._id.toString().slice(-6).toUpperCase();
                const product = order.product?.title || '—';
                const buyer = (order.buyer?.nickname || order.buyer?.name) || '—';
                const seller = (order.seller?.nickname || order.seller?.name) || '—';
                const price = order.priceSnapshot ? order.priceSnapshot.toLocaleString() + ' ₫' : '—';
                const delivery = order.deliveryMethod === 'pickup' ? 'Pickup' : order.deliveryMethod === 'ship' ? 'Ship' : '—';
                const payment = order.paymentMethod === 'cash' ? 'Cash' : order.paymentMethod === 'card' ? 'Card' : '—';
                return `<tr>
          <td style="font-family:var(--mono);font-size:11px;color:var(--t2)">#ORD-${orderId}</td>
          <td style="color:var(--t2);"><div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:140px;" title="${product}">${product}</div></td>
          <td style="color:var(--t2)">${buyer}</td>
          <td style="color:var(--t2)">${seller}</td>
          <td>${price}</td>
          <td style="color:var(--t2)">${delivery}</td>
          <td style="color:var(--t2)">${payment}</td>
          <td>${getStatusBadge(order.status)}</td>
        </tr>`;
              }).join('');
            }

            window.loadOrders = loadOrders;

            let currentOrderFilter = '';

            // Wire up order filter pills
            document.querySelectorAll('#aOrders .f-pill').forEach(pill => {
              pill.addEventListener('click', () => {
                document.querySelectorAll('#aOrders .f-pill').forEach(p => p.classList.remove('on'));
                pill.classList.add('on');
                const txt = pill.textContent.trim().toLowerCase();
                currentOrderFilter = txt === 'all' ? '' : txt;
                loadOrders();
              });
            });

            async function loadOrders(page = 1) {
              const tbody = document.getElementById('ordersTableBody');
              if (!tbody) return;
              tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--t2);padding:24px">Loading...</td></tr>';

              const params = new URLSearchParams({ limit: 20, page });
              if (currentOrderFilter) params.set('status', currentOrderFilter);

              try {
                const res = await fetch(`/api/admin/orders?${params}`);
                const json = await res.json();
                if (json.success) {
                  renderOrdersTable(json.data);
                  if (typeof renderPagination === 'function') {
                    renderPagination('#aOrders .pagination', json.pagination, 'loadOrders');
                  }
                } else {
                  tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--danger);padding:24px">Failed to load orders</td></tr>';
                }
              } catch {
                tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--danger);padding:24px">Network error</td></tr>';
              }
            }

            // Load on section activation (handled via dash-scripts initAdminData)
            // No redundant calls
          })();

          // ── Admin Reports Table (dynamic) ─────────────────────────────────
          (function () {
            const reasonLabels = {
              'inappropriate-content': 'Inappropriate content',
              'offensive-language': 'Offensive language',
              'fraud-scam': 'Fraud/Scam',
              'counterfeit-item': 'Counterfeit item',
              'damaged-item': 'Damaged/Missing item',
              'misleading-description': 'Misleading description',
              'fake-account': 'Fake account',
              'suspicious-behavior': 'Suspicious behavior',
              'other': 'Other'
            };

            function getReportTypeBadge(targetType) {
              return targetType === 'product'
                ? '<span class="badge badge-reported">Product</span>'
                : '<span class="badge badge-pending">User</span>';
            }

            function getStatusBadge(status) {
              const statusMap = {
                'pending': 'badge-pending',
                'under-review': 'badge-pending',
                'resolved': 'badge-completed',
                'dismissed': 'badge-cancelled'
              };
              const badge = statusMap[status] || 'badge-pending';
              const label = status.charAt(0).toUpperCase() + status.slice(1).replace('-', ' ');
              return `<span class="badge ${badge}">${label}</span>`;
            }

            function renderReportsTable(reports) {
              const tbody = document.getElementById('reportsTableBody');
              if (!tbody) return;
              if (!reports || reports.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--t2);padding:24px">No reports found</td></tr>';
                return;
              }
              tbody.innerHTML = reports.map(report => {
                const targetName = report.targetDetails
                  ? (report.targetType === 'product' ? report.targetDetails.title : report.targetDetails.nickname || report.targetDetails.name)
                  : '—';
                const reporterName = report.reporter ? report.reporter.nickname || report.reporter.name : '—';
                const date = new Date(report.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                const reasonLabel = reasonLabels[report.reason] || report.reason;

                let actionBtn = '';
                if (report.targetType === 'product') {
                  actionBtn = `<button class="act-btn primary" onclick="window.location.href='/products/${report.targetId}'">View</button>`;
                } else {
                  actionBtn = `<button class="act-btn primary" onclick="window.location.href='/user/${report.targetId}'">View</button>`;
                }

                return `<tr style="background:#fff7ed">
          <td>${getReportTypeBadge(report.targetType)}</td>
          <td><strong>${targetName}</strong></td>
          <td style="color:var(--t2)">${reporterName}</td>
          <td style="color:var(--t2);font-size:13px">${reasonLabel}</td>
          <td style="color:var(--t2);font-size:12px">${date}</td>
          <td>${getStatusBadge(report.status)}</td>
          <td><div class="tbl-actions">${actionBtn}<button class="act-btn" onclick="resolveReport('${report._id}', this)">Resolve</button></div></td>
        </tr>`;
              }).join('');
            }

            async function resolveReport(reportId, btn) {
              try {
                btn.disabled = true;
                btn.textContent = 'Resolving...';
                const res = await fetch(`/api/admin/reports/${reportId}`, {
                  method: 'PATCH',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ status: 'resolved' })
                });
                if (!res.ok) throw new Error();
                showToast('Report resolved', 'ok');
                btn.textContent = 'Resolved';
                btn.style.opacity = '0.5';
                btn.style.cursor = 'not-allowed';
                // Reload table to reflect status change
                loadReports();
              } catch {
                showToast('Failed to resolve report', 'error');
                btn.disabled = false;
                btn.textContent = 'Resolve';
              }
            }

            window.resolveReport = resolveReport;

            let currentReportFilter = 'all';

            // Wire up report filter pills
            document.querySelectorAll('#aReports .f-pill').forEach(pill => {
              pill.addEventListener('click', () => {
                document.querySelectorAll('#aReports .f-pill').forEach(p => p.classList.remove('on'));
                pill.classList.add('on');
                currentReportFilter = pill.dataset.filter || 'all';
                loadReports();
              });
            });

            async function loadReports(page = 1) {
              const tbody = document.getElementById('reportsTableBody');
              if (!tbody) return;
              tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--t2);padding:24px">Loading...</td></tr>';

              const params = new URLSearchParams({ limit: 25, page });
              if (currentReportFilter && currentReportFilter !== 'all') params.set('status', currentReportFilter);

              try {
                const res = await fetch(`/api/admin/reports?${params}`);
                const json = await res.json();
                if (json.success) {
                  renderReportsTable(json.data);
                  if (typeof renderPagination === 'function') {
                    renderPagination('#aReports .pagination', json.pagination, 'loadReports');
                  }
                } else {
                  tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--danger);padding:24px">Failed to load reports</td></tr>';
                }
              } catch {
                tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--danger);padding:24px">Network error</td></tr>';
              }
            }

            // Expose loadReports globally
            window.loadReports = loadReports;

            // Load on section activation (handled via dash-scripts initAdminData)
            // No redundant calls here
            async function syncSellerRatings() {
              if (!confirm('This will recalculate ratings for ALL users in the database based on their product reviews. Continue?')) return;
              try {
                if (typeof showToast === 'function') showToast('Synchronizing ratings...', 'info');
                const res = await fetch('/api/admin/sync-ratings', { method: 'POST' });
                const json = await res.json();
                if (json.success) {
                  if (typeof showToast === 'function') showToast(json.message || 'Sync complete', 'ok');
                  setTimeout(() => location.reload(), 2000);
                } else {
                  showToast(json.message || 'Sync failed', 'error');
                }
              } catch (err) {
                showToast('Network error', 'error');
              }
            }
            window.syncSellerRatings = syncSellerRatings;
          })();
        </script>
</body>

</html>