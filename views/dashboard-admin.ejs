        <div class="stat-card"><div class="stat-top"><div><div class="stat-label">Người dùng mới (7 ngày)</div></div><div class="stat-icon" style="background:#dcfce7;color:#16a34a"><svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg></div></div><div class="stat-val">86</div><div class="stat-delta delta-up">↑ +14%</div></div>
        <div class="stat-card"><div class="stat-top"><div><div class="stat-label">Tỷ lệ quay lại</div></div><div class="stat-icon" style="background:#dbeafe;color:#2563eb"><svg viewBox="0 0 24 24"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 014-4h14M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 01-4 4H3"/></svg></div></div><div class="stat-val">68%</div><div class="stat-delta delta-up">↑ +3 điểm</div></div>
        <div class="stat-card"><div class="stat-top"><div><div class="stat-label">Giá trị đơn trung bình</div></div><div class="stat-icon" style="background:#fef3c7;color:#d97706"><svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6"/></svg></div></div><div class="stat-val">435K ₫</div><div class="stat-delta delta-dn">↓ -2%</div></div>
        <div class="stat-card"><div class="stat-top"><div><div class="stat-label">Listing mới / ngày</div></div><div class="stat-icon" style="background:#ede9fe;color:#7c3aed"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/></svg></div></div><div class="stat-val">11.4</div><div class="stat-delta delta-up">↑ +6%</div></div>
      </div>

      <div class="card" style="margin-bottom:22px">
        <div class="card-head"><div><div class="card-title">User growth — 2026</div><div class="card-sub">Cumulative registered accounts</div></div></div>
        <div style="position:relative;height:220px"><canvas id="cUserGrowth"></canvas></div>
      </div>

      <div class="three-col">
        <div class="card">
          <div class="card-head"><div><div class="card-title">Delivery method</div><div class="card-sub">Pickup vs Ship</div></div></div>
          <div style="position:relative;height:150px;margin-bottom:10px"><canvas id="cDelivery"></canvas></div>
          <div class="legend" style="flex-direction:column;gap:6px">
            <span class="leg-item"><span class="leg-dot" style="background:#2563eb"></span>Pickup — 63%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#22c55e"></span>Ship — 37%</span>
          </div>
        </div>
        <div class="card">
          <div class="card-head"><div><div class="card-title">Payment methods</div><div class="card-sub">Cash vs Card</div></div></div>
          <div style="position:relative;height:150px;margin-bottom:10px"><canvas id="cPayment"></canvas></div>
          <div class="legend" style="flex-direction:column;gap:6px">
            <span class="leg-item"><span class="leg-dot" style="background:#f59e0b"></span>Cash — 71%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#8b5cf6"></span>Card — 29%</span>
          </div>
        </div>
        <div class="card">
          <div class="card-head"><div><div class="card-title">Order status</div><div class="card-sub">Distribution this month</div></div></div>
          <div style="position:relative;height:150px;margin-bottom:10px"><canvas id="cOrderStatus"></canvas></div>
          <div class="legend" style="flex-direction:column;gap:6px">
            <span class="leg-item"><span class="leg-dot" style="background:#22c55e"></span>Completed — 62%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#2563eb"></span>Confirmed — 23%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#f59e0b"></span>Pending — 7%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#ef4444"></span>Cancelled — 8%</span>
          </div>
        </div>
      </div>
    </section>
