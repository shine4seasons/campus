<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Revenue — Campus Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
</head>
<body>
<%- include('partials/navbar') %>
<%- include('partials/sidebar') %>

<main class="main">
  <div class="content">

    <!-- ── SECTION: Revenue ── -->

      <div class="stat-grid">
        <div class="stat-card">
          <div class="stat-top"><div><div class="stat-label">Total revenue</div></div></div>
          <div class="stat-val" id="revTotal">-- VND</div>
          <div class="stat-delta delta-neu">All time</div>
        </div>
        <div class="stat-card">
          <div class="stat-top"><div><div class="stat-label">This month</div></div></div>
          <div class="stat-val" id="revMonth">-- VND</div>
          <div class="stat-delta delta-up"><i data-lucide="trending-up" style="width:14px;height:14px;display:inline-block;vertical-align:middle;margin-right:4px;"></i> +0%</div>
        </div>
        <div class="stat-card">
          <div class="stat-top"><div><div class="stat-label">Total sold</div></div></div>
          <div class="stat-val" id="revSold">-- items</div>
          <div class="stat-delta delta-neu">All time</div>
        </div>
        <div class="stat-card">
          <div class="stat-top"><div><div class="stat-label">Avg. value / order</div></div></div>
          <div class="stat-val" id="revAvg">-- VND</div>
          <div class="stat-delta delta-neu">--</div>
        </div>
      </div>
      <div class="card" style="margin-bottom:22px">
        <div class="card-head">
          <div><div class="card-title">Revenue trend</div><div class="card-sub">By month (VND thousands)</div></div>
        </div>
        <div style="position:relative;height:220px"><canvas id="cRevTrend"></canvas></div>
      </div>
      <div class="tbl-wrap">
      <div class="tbl-toolbar"><div><div class="tbl-title">Completed transactions history</div></div></div>
        <table>
        
          <thead><tr><th>Product</th><th>Buyer</th><th>Date</th><th>Price</th><th>Method</th></tr></thead>
          <tbody id="revHistoryTbody">
            <tr><td colspan="5" style="text-align:center;padding:15px;color:var(--t2)">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </section>

  </div><!-- /.content -->
</main>

<div id="toast-wrap"></div>

<script>window.INITIAL_SECTION = 'sRevenue';</script>
<%- include('partials/dashboard-scripts') %>
</body>
</html>
