<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Revenue — Campus Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
</head>
<body>
<%- include('partials/navbar') %>
<%- include('partials/sidebar') %>

<main class="main">
  <div class="content">

    <!-- ── SECTION: Revenue ── -->
    <section class="section active" id="sRevenue" data-title="Revenue" data-sub="Your revenue statistics" data-cta="Export report">
      <div class="stat-grid">
        <div class="stat-card">
          <div class="stat-top"><div><div class="stat-label">Total revenue</div></div></div>
          <div class="stat-val">28.4M ₫</div>
          <div class="stat-delta delta-neu">All time</div>
        </div>
        <div class="stat-card">
          <div class="stat-top"><div><div class="stat-label">This month</div></div></div>
          <div class="stat-val">4.2M ₫</div>
          <div class="stat-delta delta-up">↑ +18%</div>
        </div>
        <div class="stat-card">
          <div class="stat-top"><div><div class="stat-label">Total sold</div></div></div>
          <div class="stat-val">28 items</div>
          <div class="stat-delta delta-neu">Over 20 listings</div>
        </div>
        <div class="stat-card">
          <div class="stat-top"><div><div class="stat-label">Avg. value / order</div></div></div>
          <div class="stat-val">1.01M ₫</div>
          <div class="stat-delta delta-up">↑ +5%</div>
        </div>
      </div>
      <div class="card" style="margin-bottom:22px">
        <div class="card-head">
          <div><div class="card-title">Revenue trend</div><div class="card-sub">By month (₫ thousands)</div></div>
        </div>
        <div style="position:relative;height:220px"><canvas id="cRevTrend"></canvas></div>
      </div>
      <div class="tbl-wrap">
      <div class="tbl-toolbar"><div><div class="tbl-title">Completed transactions history</div></div></div>
        <table>
        
          <thead><tr><th>Product</th><th>Buyer</th><th>Date</th><th>Price</th><th>Method</th></tr></thead>
          <tbody>
            <tr><td>Sony WH-1000XM4</td><td style="color:var(--t2)">Lan Chi</td><td style="color:var(--t2)">28/03/2026</td><td style="font-weight:700;color:#16a34a">3,200,000 ₫</td><td style="color:var(--t2)">Ship</td></tr>
            <tr><td>Casio FX-580</td><td style="color:var(--t2)">Tú Anh</td><td style="color:var(--t2)">20/03/2026</td><td style="font-weight:700;color:#16a34a">320,000 ₫</td><td style="color:var(--t2)">Pickup</td></tr>
            <tr><td>Giáo trình Toán</td><td style="color:var(--t2)">Hải Yến</td><td style="color:var(--t2)">15/03/2026</td><td style="font-weight:700;color:#16a34a">60,000 ₫</td><td style="color:var(--t2)">Pickup</td></tr>
            <tr><td>Balo laptop</td><td style="color:var(--t2)">Hùng Anh</td><td style="color:var(--t2)">05/03/2026</td><td style="font-weight:700;color:#16a34a">280,000 ₫</td><td style="color:var(--t2)">Pickup</td></tr>
          </tbody>
        </table>
      </div>
    </section>

  </div><!-- /.content -->
</main>

<div id="toast-wrap"></div>

<script>window.INITIAL_SECTION = 'sRevenue';</script>
<%- include('partials/dashboard-scripts') %>
</body>
</html>
