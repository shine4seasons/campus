<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Campus Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
   <link rel="stylesheet" href="/css/dashboard.css">
   <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <%- include('partials/navbar') %>
<!-- ══════════════════════════════ SIDEBAR ══════════════════════════════ -->
<aside class="sidebar">
  <div class="sb-brand">
    <div class="sb-logo">
      <div class="sb-logo-icon">
        <svg viewBox="0 0 24 24" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
      </div>
      <div>
        <div class="sb-logo-name">Campus MKT</div>
        <div class="sb-logo-tag">Management Console</div>
      </div>
    </div>
  </div>

  <!-- Role switcher -->
  <div class="role-toggle">
    <button class="role-btn active" id="rAdmin" onclick="switchRole('admin')">Admin</button>
    <button class="role-btn" id="rSeller" onclick="switchRole('seller')">Seller</button>
  </div>

  <!-- Admin nav -->
  <div class="sb-section" id="adminNav">
    <div class="sb-group-label">Overview</div>
    <div class="nav-item active" onclick="nav(this,'aDash')">
      <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Dashboard
    </div>
    <div class="nav-item" onclick="nav(this,'aAnalytics')">
      <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      Analytics
    </div>

    <div class="sb-group-label">Management</div>
    <div class="nav-item" onclick="nav(this,'aUsers')">
      <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
      Users
      <span class="nav-badge">3</span>
    </div>
    <div class="nav-item" onclick="nav(this,'aProducts')">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg>
      Products
      <span class="nav-badge">5</span>
    </div>
    <div class="nav-item" onclick="nav(this,'aOrders')">
      <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      Orders
    </div>

    <div class="sb-group-label">Moderation</div>
    <div class="nav-item" onclick="nav(this,'aReports')">
      <svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      Reports
      <span class="nav-badge">3</span>
    </div>
    <div class="nav-item" onclick="nav(this,'aSettings')">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
      Settings
    </div>
  </div>

  <!-- Seller nav -->
  <div class="sb-section" id="sellerNav" style="display:none">
    <div class="sb-group-label">Overview</div>
    <div class="nav-item active" onclick="nav(this,'sDash')">
      <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Dashboard
    </div>

    <div class="sb-group-label">My Store</div>
    <div class="nav-item" onclick="nav(this,'sListings')">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg>
      Listings
    </div>
    <div class="nav-item" onclick="nav(this,'sOrders')">
      <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      Orders
      <span class="nav-badge">2</span>
    </div>
    <div class="nav-item" onclick="nav(this,'sRevenue')">
      <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6"/></svg>
      Revenue
    </div>
    <div class="nav-item" onclick="nav(this,'sMessages')">
      <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      Messages
      <span class="nav-badge">4</span>
    </div>
    <div class="nav-item" onclick="nav(this,'sProfile')">
      <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      My Profile
    </div>
  </div>

  <div class="sb-footer">
    <div class="sb-avatar" id="sbAvatar">A</div>
    <div>
      <div class="sb-uname" id="sbName">Admin User</div>
      <div class="sb-urole" id="sbRole">Super Admin</div>
    </div>
    <button class="sb-logout" onclick="showToast('Đã đăng xuất','info')">
      <svg viewBox="0 0 24 24" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
    </button>
  </div>
</aside>

<!-- ══════════════════════════════ MAIN ══════════════════════════════ -->
<main class="main">

  <!-- Topbar -->
  <header class="topbar">
    <div>
      <div class="pg-title" id="pgTitle">Dashboard overview</div>
      <div class="pg-sub" id="pgSub">Thứ Hai, 6 tháng 4, 2026</div>
    </div>
    <div class="topbar-right">
      <div class="tb-search">
        <svg viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Tìm kiếm...">
      </div>
      <button class="tb-icon-btn" onclick="showToast('Không có thông báo mới','info')">
        <svg viewBox="0 0 24 24" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"/></svg>
        <div class="tb-notif-dot"></div>
      </button>
      <button class="btn btn-outline" id="tbExport" onclick="showToast('Đang xuất dữ liệu...','info')">
        <svg viewBox="0 0 24 24" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Export
      </button>
      <button class="btn btn-primary" id="tbPrimary" onclick="showToast('Đang chuyển hướng...','ok')">
        <svg viewBox="0 0 24 24" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        <span id="tbPrimaryLabel">Thêm sản phẩm</span>
      </button>
    </div>
  </header>

  <div class="content">

    <!-- ╔══════════════════════════════╗
         ║     ADMIN — DASHBOARD        ║
         ╚══════════════════════════════╝ -->
    <section class="section active" id="aDash">
      <div class="stat-grid">
        <div class="stat-card">
          <div class="stat-top">
            <div><div class="stat-label">Tổng người dùng</div></div>
            <div class="stat-icon" style="background:#dbeafe;color:#2563eb">
              <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
          </div>
          <div class="stat-val">1,284</div>
          <div class="stat-delta delta-up">↑ 12% so với tháng trước</div>
        </div>
        <div class="stat-card">
          <div class="stat-top">
            <div><div class="stat-label">Listing đang hoạt động</div></div>
            <div class="stat-icon" style="background:#dcfce7;color:#16a34a">
              <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg>
            </div>
          </div>
          <div class="stat-val">347</div>
          <div class="stat-delta delta-up">↑ +8 hôm nay</div>
        </div>
        <div class="stat-card">
          <div class="stat-top">
            <div><div class="stat-label">Đơn hàng tháng này</div></div>
            <div class="stat-icon" style="background:#fef3c7;color:#d97706">
              <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
          </div>
          <div class="stat-val">98</div>
          <div class="stat-delta delta-up">↑ 23% vs tháng trước</div>
        </div>
        <div class="stat-card">
          <div class="stat-top">
            <div><div class="stat-label">GMV tháng này</div></div>
            <div class="stat-icon" style="background:#ede9fe;color:#7c3aed">
              <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6"/></svg>
            </div>
          </div>
          <div class="stat-val">42.6M ₫</div>
          <div class="stat-delta delta-dn">↓ -4% vs tháng trước</div>
        </div>
      </div>

      <div class="charts-row">
        <div class="card">
          <div class="card-head">
            <div><div class="card-title">Doanh thu theo tháng (GMV)</div><div class="card-sub">Tổng giao dịch, 2026</div></div>
            <a class="card-action" href="#">Xem chi tiết</a>
          </div>
          <div class="legend">
            <span class="leg-item"><span class="leg-dot" style="background:#2563eb"></span>GMV (₫M)</span>
            <span class="leg-item"><span class="leg-dot" style="background:#22c55e"></span>Đơn hàng</span>
          </div>
          <div style="position:relative;height:200px"><canvas id="cAdminGMV"></canvas></div>
        </div>
        <div class="card">
          <div class="card-head">
            <div><div class="card-title">Danh mục sản phẩm</div><div class="card-sub">Phân bổ listing</div></div>
          </div>
          <div style="position:relative;height:170px;margin-bottom:12px"><canvas id="cAdminCat"></canvas></div>
          <div class="legend" style="flex-direction:column;gap:7px">
            <span class="leg-item"><span class="leg-dot" style="background:#2563eb"></span>Electronics 28%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#22c55e"></span>Books 24%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#f59e0b"></span>Clothing 19%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#8b5cf6"></span>Khác 29%</span>
          </div>
        </div>
      </div>

      <div class="two-col">
        <div class="card">
          <div class="card-head"><div><div class="card-title">Top sellers</div><div class="card-sub">Theo doanh thu tháng này</div></div></div>
          <div class="list-item">
            <div class="li-rank gold">1</div>
            <div class="li-avatar" style="background:#fef3c7;color:#b45309">TN</div>
            <div class="li-info"><div class="li-name">Trần Ngọc</div><div class="li-sub">28 sales · ⭐ 4.9 · HUST</div></div>
            <div class="li-val">12.4M ₫</div>
          </div>
          <div class="list-item">
            <div class="li-rank silver">2</div>
            <div class="li-avatar" style="background:#dcfce7;color:#15803d">AL</div>
            <div class="li-info"><div class="li-name">An Lê</div><div class="li-sub">21 sales · ⭐ 4.8 · NEU</div></div>
            <div class="li-val">9.1M ₫</div>
          </div>
          <div class="list-item">
            <div class="li-rank bronze">3</div>
            <div class="li-avatar" style="background:#dbeafe;color:#1d4ed8">MH</div>
            <div class="li-info"><div class="li-name">Minh Hoa</div><div class="li-sub">17 sales · ⭐ 4.7 · VNU</div></div>
            <div class="li-val">7.8M ₫</div>
          </div>
          <div class="list-item">
            <div class="li-rank">4</div>
            <div class="li-avatar" style="background:#ede9fe;color:#6d28d9">PQ</div>
            <div class="li-info"><div class="li-name">Phúc Quang</div><div class="li-sub">15 sales · ⭐ 4.6 · HUST</div></div>
            <div class="li-val">6.2M ₫</div>
          </div>
          <div class="list-item">
            <div class="li-rank">5</div>
            <div class="li-avatar" style="background:#fee2e2;color:#b91c1c">LT</div>
            <div class="li-info"><div class="li-name">Lan Tú</div><div class="li-sub">12 sales · ⭐ 4.5 · FTU</div></div>
            <div class="li-val">4.9M ₫</div>
          </div>
        </div>
        <div class="card">
          <div class="card-head"><div><div class="card-title">Platform health</div><div class="card-sub">Chỉ số vận hành</div></div></div>
          <div class="prog-row">
            <div class="prog-item">
              <div class="prog-meta"><span class="prog-label">Tỷ lệ hoàn thành đơn</span><span class="prog-val">84%</span></div>
              <div class="prog-bar"><div class="prog-fill" style="width:84%;background:#2563eb"></div></div>
            </div>
            <div class="prog-item">
              <div class="prog-meta"><span class="prog-label">Seller phản hồi</span><span class="prog-val">91%</span></div>
              <div class="prog-bar"><div class="prog-fill" style="width:91%;background:#22c55e"></div></div>
            </div>
            <div class="prog-item">
              <div class="prog-meta"><span class="prog-label">Profile hoàn chỉnh</span><span class="prog-val">62%</span></div>
              <div class="prog-bar"><div class="prog-fill" style="width:62%;background:#f59e0b"></div></div>
            </div>
            <div class="prog-item">
              <div class="prog-meta"><span class="prog-label">Tỷ lệ huỷ đơn</span><span class="prog-val">8%</span></div>
              <div class="prog-bar"><div class="prog-fill" style="width:8%;background:#ef4444"></div></div>
            </div>
            <div class="prog-item">
              <div class="prog-meta"><span class="prog-label">Đánh giá trung bình</span><span class="prog-val">4.7/5</span></div>
              <div class="prog-bar"><div class="prog-fill" style="width:94%;background:#8b5cf6"></div></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ╔══════════════════════════════╗
         ║     ADMIN — ANALYTICS        ║
         ╚══════════════════════════════╝ -->
    <section class="section" id="aAnalytics">
      <div class="stat-grid">
        <div class="stat-card"><div class="stat-top"><div><div class="stat-label">Người dùng mới (7 ngày)</div></div><div class="stat-icon" style="background:#dcfce7;color:#16a34a"><svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg></div></div><div class="stat-val">86</div><div class="stat-delta delta-up">↑ +14%</div></div>
        <div class="stat-card"><div class="stat-top"><div><div class="stat-label">Tỷ lệ quay lại</div></div><div class="stat-icon" style="background:#dbeafe;color:#2563eb"><svg viewBox="0 0 24 24"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 014-4h14M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 01-4 4H3"/></svg></div></div><div class="stat-val">68%</div><div class="stat-delta delta-up">↑ +3 điểm</div></div>
        <div class="stat-card"><div class="stat-top"><div><div class="stat-label">Giá trị đơn trung bình</div></div><div class="stat-icon" style="background:#fef3c7;color:#d97706"><svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6"/></svg></div></div><div class="stat-val">435K ₫</div><div class="stat-delta delta-dn">↓ -2%</div></div>
        <div class="stat-card"><div class="stat-top"><div><div class="stat-label">Listing mới / ngày</div></div><div class="stat-icon" style="background:#ede9fe;color:#7c3aed"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/></svg></div></div><div class="stat-val">11.4</div><div class="stat-delta delta-up">↑ +6%</div></div>
      </div>

      <div class="card" style="margin-bottom:22px">
        <div class="card-head"><div><div class="card-title">Tăng trưởng người dùng — 2026</div><div class="card-sub">Tích lũy tài khoản đã đăng ký</div></div></div>
        <div style="position:relative;height:220px"><canvas id="cUserGrowth"></canvas></div>
      </div>

      <div class="three-col">
        <div class="card">
          <div class="card-head"><div><div class="card-title">Hình thức giao hàng</div><div class="card-sub">Pickup vs Ship</div></div></div>
          <div style="position:relative;height:150px;margin-bottom:10px"><canvas id="cDelivery"></canvas></div>
          <div class="legend" style="flex-direction:column;gap:6px">
            <span class="leg-item"><span class="leg-dot" style="background:#2563eb"></span>Tự đến nhận — 63%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#22c55e"></span>Giao tận nơi — 37%</span>
          </div>
        </div>
        <div class="card">
          <div class="card-head"><div><div class="card-title">Phương thức thanh toán</div><div class="card-sub">Cash vs Card</div></div></div>
          <div style="position:relative;height:150px;margin-bottom:10px"><canvas id="cPayment"></canvas></div>
          <div class="legend" style="flex-direction:column;gap:6px">
            <span class="leg-item"><span class="leg-dot" style="background:#f59e0b"></span>Tiền mặt — 71%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#8b5cf6"></span>Thẻ ngân hàng — 29%</span>
          </div>
        </div>
        <div class="card">
          <div class="card-head"><div><div class="card-title">Trạng thái đơn hàng</div><div class="card-sub">Phân bổ tháng này</div></div></div>
          <div style="position:relative;height:150px;margin-bottom:10px"><canvas id="cOrderStatus"></canvas></div>
          <div class="legend" style="flex-direction:column;gap:6px">
            <span class="leg-item"><span class="leg-dot" style="background:#22c55e"></span>Completed — 62%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#2563eb"></span>Confirmed — 23%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#f59e0b"></span>Pending — 7%</span>
            <span class="leg-item"><span class="leg-dot" style="background:#ef4444"></span>Cancelled — 8%</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ╔══════════════════════════════╗
         ║     ADMIN — USERS            ║
         ╚══════════════════════════════╝ -->
    <section class="section" id="aUsers">
      <div class="tbl-wrap">
        <div class="tbl-toolbar">
          <div><div class="tbl-title">Tất cả người dùng</div><div class="tbl-count">1,284 tài khoản</div></div>
          <div style="display:flex;align-items:center;gap:10px">
            <div class="filter-pills">
              <button class="f-pill on">Tất cả</button>
              <button class="f-pill">Đang hoạt động</button>
              <button class="f-pill">Bị cấm</button>
