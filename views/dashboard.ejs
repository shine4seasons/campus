            <div class="form-group"><label class="form-label">Giới thiệu bản thân</label><textarea class="form-textarea">Bán đồ điện tử, sách giáo khoa tại HUST. Giao dịch nhanh, uy tín. Liên hệ trực tiếp để được hỗ trợ.</textarea></div>
            <div style="display:flex;gap:10px">
              <button class="btn btn-primary" onclick="showToast('Đã lưu thông tin','ok')">Lưu thay đổi</button>
              <button class="btn btn-outline" onclick="showToast('Đã hủy chỉnh sửa','info')">Hủy</button>
            </div>
