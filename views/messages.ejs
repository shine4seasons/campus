<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/messages.css">
  <style>
    /* ── Product context banner ── */
    .product-banner {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 16px;
      background: #F0F4FF;
      border-top: 1px solid #D6E0FF;
      border-bottom: 1px solid #D6E0FF;
      flex-shrink: 0;
      animation: bannerSlideIn 0.25s ease;
    }
    @keyframes bannerSlideIn {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .product-banner-img {
      width: 44px;
      height: 44px;
      object-fit: cover;
      border-radius: 8px;
      border: 1px solid #C5D2FF;
      flex-shrink: 0;
      background: #E4E7F2;
    }
    .product-banner-img-placeholder {
      width: 44px;
      height: 44px;
      border-radius: 8px;
      border: 1px solid #C5D2FF;
      flex-shrink: 0;
      background: #E4E7F2;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    }
    .product-banner-info { flex: 1; min-width: 0; }
    .product-banner-label {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: #1B5EFF;
      margin-bottom: 2px;
    }
    .product-banner-title {
      font-weight: 700;
      font-size: 13px;
      color: #0D0F1A;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .product-banner-meta {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 2px;
    }
    .product-banner-price {
      font-weight: 800;
      color: #1B5EFF;
      font-size: 13px;
    }
    .product-banner-cond {
      font-size: 11px;
      color: #6B7399;
      background: #E8EDFF;
      border-radius: 4px;
      padding: 1px 6px;
    }
    /* ── Date divider ── */
    .date-divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 18px 0 10px;
      padding: 0 4px;
    }
    .date-divider::before,
    .date-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #E4E7F2;
    }
    .date-divider-label {
      font-size: 11px;
      font-weight: 600;
      color: #8890B0;
      white-space: nowrap;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="chat-container">
    <!-- SIDEBAR (Inbox) -->
    <div class="chat-sidebar">
      <div class="sidebar-header">Inbox <span id="mode-label" style="font-weight:700;margin-left:8px;color:#1B5EFF;font-size:12px;"></span></div>
      <div class="conv-list" id="conv-list">
        <!-- Rendered by JS -->
      </div>
    </div>

    <!-- MAIN CHAT -->
    <div class="chat-main">
      <div class="chat-empty" id="chat-empty">
        <svg width="64" height="64" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        <p>Select a conversation to start messaging</p>
      </div>

      <div class="chat-header" id="chat-header">
        <div class="conv-avatar" id="header-avatar" style="width:40px;height:40px;font-size:16px;"></div>
        <div>
          <div class="chat-partner-name" id="header-name"></div>
          <div class="chat-partner-status">Active now</div>
        </div>
      </div>

      <div class="chat-messages" id="chat-messages" style="display:none;">
        <!-- Rendered by JS -->
      </div>

      <!-- Product context banner (shown when coming from a product page or stored) -->
      <div class="product-banner" id="product-banner" style="display:none;"></div>

      <div class="chat-input-area" id="chat-input-area">
        <input type="text" id="chat-input" class="chat-input" placeholder="Type a message..." autocomplete="off">
        <button class="chat-send-btn" id="chat-send-btn" onclick="sendMessage()">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="margin-left:-2px;"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </div>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
      // socket.io client will be loaded dynamically below
      const MY_USER_ID = '<%= String(user._id) %>';
      let currentConvId = '<%= conversationId || "" %>';
      let pollInterval = null;
      let autoScroll = true;
      const socket = io ? io() : null;
      let joinedConv = null;

      if (socket) {
        socket.on('connect', () => {
          // connection ready
        });

        socket.on('message', (msg) => {
          try {
            // msg.conversationId may be ObjectId or string
            const convId = msg.conversationId ? String(msg.conversationId) : null;
            if (convId && convId === currentConvId) {
              // refresh current messages
              fetchMessages();
            }
            // update inbox for new message
            fetchInbox();
          } catch (e) { console.error('socket message handler error', e); }
        });
      }

    // ── Product Banner ──────────────────────────────────────────────────────
    const COND_LABEL = { new:'New', 'like-new':'Like new', good:'Good', fair:'Fair' };

    function renderProductBanner(convId, productData) {
      const banner = document.getElementById('product-banner');
      if (!banner || !productData) return;
      // Persist to localStorage so banner shows on reload / direct link
      try { localStorage.setItem('conv_product_' + convId, JSON.stringify(productData)); } catch(e) {}

      const priceStr = new Intl.NumberFormat('vi-VN', { style:'currency', currency:'VND' }).format(productData.price);
      const condLabel = COND_LABEL[productData.condition] || productData.condition || '';
      const imgHtml = productData.image
        ? `<img class="product-banner-img" src="${productData.image}" alt="">`
        : `<div class="product-banner-img-placeholder"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73L13 3l-7 3.27A2 2 0 0 0 5 8v8a2 2 0 0 0 1 1.73L11 21l7-3.27A2 2 0 0 0 21 16z"/><path d="M12 3v10"/></svg></div>`;

      banner.innerHTML = `
        ${imgHtml}
        <div class="product-banner-info">
          <div class="product-banner-label">Discussing product</div>
          <div class="product-banner-title">${productData.title || ''}</div>
          <div class="product-banner-meta">
            <span class="product-banner-price">${priceStr}</span>
            ${condLabel ? `<span class="product-banner-cond">${condLabel}</span>` : ''}
          </div>
        </div>
      `;
      banner.style.display = 'flex';
    }

    function tryLoadBannerFromStorage(convId) {
      try {
        const raw = localStorage.getItem('conv_product_' + convId);
        if (raw) renderProductBanner(convId, JSON.parse(raw));
        else document.getElementById('product-banner').style.display = 'none';
      } catch(e) {}
    }

    // On page load: parse ?pd= param if present
    (function parsePdParam() {
      const params = new URLSearchParams(window.location.search);
      const pdRaw  = params.get('pd');
      if (pdRaw && currentConvId) {
        try {
          const productData = JSON.parse(decodeURIComponent(pdRaw));
          renderProductBanner(currentConvId, productData);
        } catch(e) {}
        // Strip ?pd= from URL
        const clean = new URL(window.location.href);
        clean.searchParams.delete('pd');
        window.history.replaceState(null, '', clean.toString());
      }
    })();

    // ── Date divider helpers ────────────────────────────────────────────────
    /**
     * Returns a smart date label for a chat date divider.
     * - Same day as today   → "Today"
     * - Yesterday           → "Yesterday"
     * - Same year & month   → "Monday 15"  (weekday + day)
     * - Same year           → "March 15"   (month + day)
     * - Older               → "March 15, 2023"
     */
    function formatDateLabel(dateStr) {
      const now = new Date();
      const d   = new Date(dateStr);

      const nowY = now.getFullYear(), nowM = now.getMonth(), nowD = now.getDate();
      const dY   = d.getFullYear(),   dM   = d.getMonth(),   dD   = d.getDate();

      if (dY === nowY && dM === nowM && dD === nowD) return 'Today';

      const yest = new Date(now);
      yest.setDate(yest.getDate() - 1);
      if (dY === yest.getFullYear() && dM === yest.getMonth() && dD === yest.getDate()) return 'Yesterday';

      if (dY === nowY && dM === nowM) {
        // Same year, same month → show weekday + numeric day
        return d.toLocaleDateString('en-US', { weekday: 'long' }) + ' ' + dD;
      }

      if (dY === nowY) {
        // Same year, different month → show "March 15"
        return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
      }

      // Different year → full date
      return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    }

    /** Returns "YYYY-MM-DD" string for grouping messages by calendar day */
    function dayKey(dateStr) {
      const d = new Date(dateStr);
      return d.getFullYear() + '-' + d.getMonth() + '-' + d.getDate();
    }

    // ── Inbox ───────────────────────────────────────────────────────────────
    async function fetchInbox() {
      try {
        const res = await fetch('/api/chat', { credentials: 'include' });
        const json = await res.json();
        if (json.success) renderInbox(json.data);
      } catch (err) { console.error('Error fetching inbox:', err); }
    }

    function renderInbox(convs) {
      const list = document.getElementById('conv-list');
      // Filter conversations according to current UI mode (buyer/seller)
      const uiMode = (localStorage.getItem('campus_mode') || 'buyer');
      document.getElementById('mode-label').textContent = uiMode === 'seller' ? 'Seller view' : 'Buyer view';

      if (convs.length === 0) {
        list.innerHTML = '<div style="padding:20px;text-align:center;color:#8890B0;font-size:14px;">No messages yet.</div>';
        return;
      }
        // Apply mode filter: sellers see conversations where they are the product seller;
        // buyers see conversations where they are the buyer (i.e., not the product seller).
        const filtered = convs.filter(c => {
          if (uiMode === 'seller') return c.isSellerConversation;
          return !c.isSellerConversation;
        });

        if (filtered.length === 0) {
          list.innerHTML = '<div style="padding:20px;text-align:center;color:#8890B0;font-size:14px;">No messages for current mode.</div>';
          return;
        }

        list.innerHTML = filtered.map(c => {
        // Prefer server-provided partner object, fall back to client-side detection.
        const partner = c.partner || (c.participants ? c.participants.find(p => String(p._id) !== MY_USER_ID) : null) || { name: 'Unknown', nickname: '' };
        const name = partner.nickname || partner.name || 'Unknown';
        const initial = (name && name.charAt) ? name.charAt(0).toUpperCase() : '?';
        const activeClass = c._id === currentConvId ? 'active' : '';
        const unreadHtml = c.unreadCount > 0 ? `<div class="unread-badge">${c.unreadCount}</div>` : '';
        const prodName = c.product ? c.product.title : 'Deleted Product';

        return `
          <div class="conv-item ${activeClass}" onclick="selectConversation('${c._id}', '${name}', '${encodeURIComponent(JSON.stringify(partner))}')">
            <div class="conv-avatar" style="background:linear-gradient(135deg,#667eea,#764ba2);">${initial}</div>
            <div class="conv-info">
              <div style="display:flex;align-items:center;">
                <div class="conv-name">${name}</div>
                ${unreadHtml}
              </div>
              <div class="conv-product"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-right:6px;vertical-align:middle;display:inline-block"><path d="M21 16V8a2 2 0 0 0-1-1.73L13 3l-7 3.27A2 2 0 0 0 5 8v8a2 2 0 0 0 1 1.73L11 21l7-3.27A2 2 0 0 0 21 16z"/><path d="M12 3v10"/></svg> ${prodName}</div>
              <div class="conv-lastmsg">${c.lastMessage || '...'}</div>
            </div>
          </div>
        `;
      }).join('');

      // If a conversationId was provided (via ?id=...), attempt to auto-select
      // the matching conversation after the inbox has been rendered.
      if (currentConvId) {
        // small timeout to ensure DOM is painted
        setTimeout(() => {
          const convItem = document.querySelector(`.conv-item[onclick*="${currentConvId}"]`);
          if (convItem) convItem.click();
        }, 50);
      }
    }

    window.selectConversation = async function(convId, partnerName, partnerDataRaw) {
      currentConvId = convId;
        // join socket room
        if (socket) {
          if (joinedConv && joinedConv !== convId) socket.emit('leaveConv', joinedConv);
          socket.emit('joinConv', convId);
          joinedConv = convId;
        }
      tryLoadBannerFromStorage(convId);
      document.getElementById('chat-empty').style.display = 'none';
      document.getElementById('chat-header').classList.add('active');
      document.getElementById('chat-messages').style.display = 'flex';
      document.getElementById('chat-input-area').classList.add('active');
      document.getElementById('header-name').textContent = partnerName;
      document.getElementById('header-avatar').textContent = partnerName.charAt(0).toUpperCase();
      document.getElementById('chat-input').focus();

      autoScroll = true;
      await fetchMessages();
      fetchInbox();

      window.history.replaceState(null, '', '/messages?id=' + convId);
    };

    // ── Messages ────────────────────────────────────────────────────────────
    async function fetchMessages() {
      if (!currentConvId) return;
      try {
        const res = await fetch('/api/chat/' + currentConvId + '/messages', { credentials: 'include' });
        const json = await res.json();
        if (json.success) renderMessages(json.data);
      } catch (err) { console.error('Error fetching messages:', err); }
    }

    function renderMessages(messages) {
      const container   = document.getElementById('chat-messages');
      const shouldScroll = autoScroll || (container.scrollTop + container.clientHeight >= container.scrollHeight - 50);

      let lastDayKey = null;
      let html = '';

      messages.forEach(m => {
        const isMe  = String(m.sender._id) === MY_USER_ID;
        const time  = new Date(m.createdAt).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
        const msgDay = dayKey(m.createdAt);

        // Insert date divider when the calendar day changes
        if (msgDay !== lastDayKey) {
          lastDayKey = msgDay;
          const label = formatDateLabel(m.createdAt);
          html += `
            <div class="date-divider">
              <span class="date-divider-label">${label}</span>
            </div>
          `;
        }

        html += `
          <div class="message-row ${isMe ? 'me' : 'other'}">
            <div class="message-bubble">${m.text.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</div>
            <div class="message-time">${time}</div>
          </div>
        `;
      });

      container.innerHTML = html;

      if (shouldScroll) {
        container.scrollTop = container.scrollHeight;
        autoScroll = false;
      }
    }

    // ── Send ────────────────────────────────────────────────────────────────
    window.sendMessage = async function() {
      const input = document.getElementById('chat-input');
      const text  = input.value.trim();
      const btn   = document.getElementById('chat-send-btn');

      if (!text || !currentConvId) return;

      input.disabled = true;
      btn.disabled   = true;

      try {
        const res = await fetch('/api/chat/' + currentConvId + '/messages', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text }),
          credentials: 'include'
        });
        const json = await res.json();
        if (json.success) {
          input.value = '';
          autoScroll  = true;
            // fetchMessages will also be triggered by socket; but call once to be safe
            await fetchMessages();
            fetchInbox();
        }
      } catch (err) { console.error('Error sending message:', err); }

      input.disabled = false;
      btn.disabled   = false;
      input.focus();
    };

    document.getElementById('chat-input').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') sendMessage();
    });

    // ── Init ────────────────────────────────────────────────────────────────
    fetchInbox();
    if (currentConvId) {
      setTimeout(() => {
        const convItem = document.querySelector(`.conv-item[onclick*="${currentConvId}"]`);
        if (convItem) convItem.click();
      }, 500);
    }

    pollInterval = setInterval(() => {
      fetchInbox();
      if (currentConvId) {
        const container = document.getElementById('chat-messages');
        if (container.scrollTop + container.clientHeight >= container.scrollHeight - 50) {
          autoScroll = true;
        }
        fetchMessages();
      }
    }, 3000);

  </script>
</body>
</html>
