<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Campus Marketplace</title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/login.css">
</head>
<body>
<%- include('partials/navbar') %>
<%- include('partials/sidebar') %>
<div class="bg-mesh"></div>
<div class="bg-grid"></div>

<div class="page">



  <!-- ── Left panel ── -->
  <div class="left-panel" id="left-panel">
    <h1 class="left-headline" id="left-headline">
      <% if (step === 'setup') { %>
        Just one more<br>step — <em>easy!</em>
      <% } else { %>
        Buy &amp; sell smarter<br>for <em>students</em>
      <% } %>
    </h1>

    <div class="feature-list" id="feature-list" style="<%= step === 'setup' ? 'display:none' : '' %>">
      <div class="feature-item">
        <div class="feature-icon">🔒</div>
        <div class="feature-text"><strong>Safe &amp; Trusted</strong></div>
      </div>
      <div class="feature-item">
        <div class="feature-icon">🤖</div>
        <div class="feature-text">
          <strong>AI-generated product descriptions</strong>
          <span>Upload a photo and AI writes a compelling description for you</span>
        </div>
      </div>
      <div class="feature-item">
        <div class="feature-icon">🛒</div>
        <div class="feature-text">
          <strong>Buy &amp; sell with one account</strong>
          <span>No separate accounts needed — list and shop from one place</span>
        </div>
      </div>
    </div>

    <div class="left-perks" id="left-perks" style="<%= step === 'setup' ? 'display:flex' : 'display:none' %>">
      <div class="perk-item">
        <strong>📦 Buy &amp; sell on the same account</strong>
        No role separation — anyone can list products for sale and buy from others.
      </div>
      <div class="perk-item">
        <strong>⭐ Reputation grows with each deal</strong>
        Your rating increases after every transaction — more stars means more trust.
      </div>
      <div class="perk-item">
        <strong>📍 Connect with your campus</strong>
        Your university helps match deals with students from the same campus.
      </div>
    </div>
  </div>

  <!-- ── Right panel ── -->
  <div class="right-panel" id="right-panel">

    <!-- ════ STEP 1: Google OAuth ════ -->
    <div class="card-step <%= step === 'setup' ? 'hidden-left' : 'visible' %>" id="step1">
      <div class="login-card">
        <div class="steps-indicator">
          <div class="step-dot active">1</div>
          <div class="step-line" id="line-1"></div>
          <div class="step-dot" id="dot-2">2</div>
        </div>

        <div class="card-eyebrow">Step 1 / 2 — Verification</div>
        <h1 class="card-title">Welcome!</h1>
        <p class="card-sub">Sign in with your Google account to get started. One account lets you both buy and sell.</p>

        <% if (error) { %>
        <div class="error-box" style="display:flex">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span>
            <% const errMsgs = { oauth_failed: 'Google OAuth failed. Please try again.', auth_failed: 'Authentication failed. Please try again.', fetch_user_failed: 'Unable to retrieve user information.' }; %>
            <%= errMsgs[error] || 'An error occurred. Please try again.' %>
          </span>
        </div>
        <% } %>

        <div id="error-box" class="error-box" style="display:none">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span id="error-text"></span>
        </div>

        <button class="btn-google" id="google-btn">
          <svg class="google-icon" width="20" height="20" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <div class="spinner-sm"></div>
          <span class="btn-google-text">Continue with Google</span>
        </button>

        <div class="card-footer">
          <a href="/">← Back to homepage</a>
        </div>
      </div>
    </div>

    <!-- ════ STEP 2: Complete profile ════ -->
    <div class="card-step <%= step === 'setup' ? 'visible' : 'hidden-right' %>" id="step2">
      <div class="login-card" style="width:100%;max-width:440px;">
        <div class="steps-indicator">
          <div class="step-dot done">✓</div>
          <div class="step-line done"></div>
          <div class="step-dot active">2</div>
        </div>

        <div class="card-eyebrow">Step 2 / 2 — Complete your profile</div>
        <h1 class="card-title" style="font-size:24px;">
          Hi, <span id="welcome-name"><%= user ? user.name.split(' ').pop() : 'there' %></span>! 👋
        </h1>
        <p class="card-sub">Add a little info so buyers and sellers can trust you more.</p>

        <div class="avatar-row">
          <div class="avatar-preview" id="avatar-preview">
            <% if (user && user.avatar) { %>
              <img src="<%= user.avatar %>" alt="<%= user.name %>">
            <% } else if (user) { %>
              <%= user.name[0].toUpperCase() %>
            <% } else { %>?<% } %>
          </div>
          <div class="avatar-meta">
            <strong><%= user ? user.name : '' %></strong>
            <span>Profile photo pulled from your Google account.</span>
          </div>
        </div>

        <div id="step2-error" class="error-box" style="display:none">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span id="step2-error-text"></span>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Display name *</label>
            <input type="text" class="form-input" id="f-nickname"
              value="<%= user ? (user.nickname || user.name || '') : '' %>"
              placeholder="E.g.: Alex Johnson" maxlength="40">
            <div class="form-hint">The name others see when transacting with you</div>
          </div>
          <div class="form-group">
            <label class="form-label">Phone number</label>
            <input type="tel" class="form-input" id="f-phone"
              value="<%= user ? (user.phone || '') : '' %>"
              placeholder="(555) 123-4567" maxlength="15">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label">University / College *</label>
            <input type="text" class="form-input" id="f-university"
              value="<%= user ? (user.university || '') : '' %>"
              placeholder="E.g.: MIT" maxlength="80">
          </div>
          <div class="form-group">
            <label class="form-label">Student ID</label>
            <input type="text" class="form-input" id="f-student-id"
              value="<%= user ? (user.studentId || '') : '' %>"
              placeholder="20210001" maxlength="20">
            <div class="form-hint">Optional</div>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Short bio</label>
          <textarea class="form-input" id="f-bio" rows="2" maxlength="200"
            style="resize:none;line-height:1.5;"
            placeholder="E.g.: 3rd-year CS student..."><%= user ? (user.bio || '') : '' %></textarea>
        </div>

        <button class="btn-submit" id="btn-submit" onclick="submitProfile()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Finish &amp; Go to homepage
        </button>

        <span class="skip-link" onclick="skipProfile()">Skip, I'll fill this in later →</span>
      </div>
    </div>

  </div>
</div>

<!-- Success flash -->
<div class="success-flash" id="success-flash">
  <div class="success-card">
    <div class="success-icon">🎉</div>
    <h3>Welcome to Campus!</h3>
    <p id="success-msg">Profile saved. Redirecting to homepage...</p>
  </div>
</div>

<script>
  // ── Google button ──────────────────────────────────
  document.getElementById('google-btn').addEventListener('click', function () {
    this.classList.add('loading');
    window.location.href = '/api/auth/google';
  });

  // ── Submit profile (Step 2) ────────────────────────
  // Cookie httpOnly được gửi tự động — không cần token
  window.submitProfile = async function () {
    const nickname   = document.getElementById('f-nickname').value.trim();
    const university = document.getElementById('f-university').value.trim();
    const phone      = document.getElementById('f-phone').value.trim();
    const studentId  = document.getElementById('f-student-id').value.trim();
    const bio        = document.getElementById('f-bio').value.trim();

    let ok = true;
    ['f-nickname', 'f-university'].forEach(id => {
      const el = document.getElementById(id);
      if (!el.value.trim()) { el.classList.add('has-error'); ok = false; }
      else el.classList.remove('has-error');
    });
    if (!ok) return;

    const btn = document.getElementById('btn-submit');
    btn.disabled = true;
    btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" style="animation:spin 0.7s linear infinite"><circle cx="12" cy="12" r="10" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2"/><path d="M12 2a10 10 0 0 1 10 10" fill="none" stroke="#fff" stroke-width="2"/></svg> Saving...';

    try {
      const res = await fetch('/api/auth/profile', {
        method: 'PATCH',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nickname, phone, university, studentId, bio, profileComplete: true }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.message || 'Failed');
      showSuccess('Profile saved. Redirecting to homepage...');
    } catch (err) {
      btn.disabled = false;
      btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Finish &amp; Go to homepage';
      const errEl = document.getElementById('step2-error');
      document.getElementById('step2-error-text').textContent = err.message || 'Unable to save profile. Please try again.';
      errEl.style.display = 'flex';
    }
  };

  window.skipProfile = async function () {
    try {
      await fetch('/api/auth/profile', {
        method: 'PATCH',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ profileComplete: true }),
      });
    } catch {}
    document.getElementById('success-msg').textContent = "You can complete your profile later in Settings.";
    showSuccess();
  };

  function showSuccess(msg) {
    if (msg) document.getElementById('success-msg').textContent = msg;
    document.getElementById('success-flash').classList.add('show');
    setTimeout(() => { window.location.href = '/'; }, 1600);
  }
</script>

</body>
</html>
