<header class="topbar">
	<div class="topbar-left">
		<a href="/" class="nav-brand" style="margin-left: 0; padding-left: 0;">
			<img src="/img/logo.png" alt="Campus Logo" style="height: 60px; width: auto; object-fit: contain; transform: scale(1.5); transform-origin: left center; margin-left: 10px;">
			<div style="display:none;">Campus Marketplace</div>
		</a>
	</div>

	<div class="topbar-center">
		<div style="display:flex;flex-direction:column;align-items:center;gap:2px;">
			<div class="pg-title" id="pgTitle"></div>
			<div class="pg-sub" id="pgSub"></div>
		</div>
		<div class="tb-search">
			<svg viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
			<input type="text" placeholder="Search...">
		</div>
	</div>

	<div class="topbar-right">
		<button class="tb-icon-btn" id="notif-btn" title="Notifications" aria-label="Notifications">
			<svg viewBox="0 0 24 24" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"/></svg>
			<div class="tb-notif-dot" id="notif-dot" style="display:none;"></div>
		</button>

		<div class="notif-dropdown" id="notif-dropdown">
			<div class="notif-header">
				<h3>Notifications</h3>
				<span class="mark-all" onclick="markAllNotificationsAsRead()">Mark all as read</span>
			</div>
			<div class="notif-list" id="notif-list">
				<div class="notif-empty">Loading...</div>
			</div>
			<div class="notif-footer">
				<a href="javascript:void(0)">View all notifications</a>
			</div>
		</div>

		<button class="tb-icon-btn" id="chat-dropdown-btn" title="Messages" aria-label="Messages">
			<svg viewBox="0 0 24 24" stroke-width="2" fill="none" stroke="currentColor"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
			<span class="tb-notif-dot" id="chat-dot" style="display:none;"></span>
		</button>

		<div class="notif-dropdown" id="chat-dropdown">
			<div class="chat-dropdown-header">
				<button class="chat-back-btn" id="chat-back-btn" style="display:none">
					<svg viewBox="0 0 24 24" width="18" height="18" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
				</button>
				<h3 id="chat-title">Messages</h3>
			</div>
			<div class="chat-dropdown-body" id="chat-dropdown-body">
				<div class="notif-empty">Loading...</div>
			</div>
			<div class="notif-footer" id="chat-footer">
				<a href="/messages">Open full chat</a>
			</div>
		</div>

		<button class="btn btn-primary" id="tbPrimaryBtn" style="display:none"><span id="tbPrimaryLabel">Action</span></button>
	</div>
</header>

<script src="/socket.io/socket.io.js"></script>
<script>
    window.SOCKET_USER_ID = '<%= user ? user._id : "" %>';
</script>
<div id="toast-wrap"></div>
<div id="modal-container"></div>
<script src="/js/notifications.js"></script>
<script src="/js/chat-dropdown.js"></script>


