<header class="topbar">
	<div class="topbar-left">
		<a href="/" class="nav-brand">
			<div class="nav-logo">Campus</div>
			<div style="display:none;">Campus Marketplace</div>
		</a>
	</div>

	<div class="topbar-center">
		<div style="display:flex;flex-direction:column;align-items:center;gap:2px;">
			<div class="pg-title" id="pgTitle"></div>
			<div class="pg-sub" id="pgSub"></div>
		</div>
		<div class="tb-search">
			<svg viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
			<input type="text" placeholder="Search...">
		</div>
	</div>

	<div class="topbar-right">
		<button class="tb-icon-btn" onclick="showToast('No notifications','info')" aria-label="Notifications">
			<svg viewBox="0 0 24 24" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"/></svg>
			<div class="tb-notif-dot"></div>
		</button>

		<a href="/messages" id="nav-chat-btn" class="nav-chat-btn" title="Messages" aria-label="Messages">
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
			<span class="nav-chat-badge" id="nav-chat-badge" style="display:none;">0</span>
		</a>

		<button class="btn btn-primary" id="tbPrimaryBtn" style="display:none"><span id="tbPrimaryLabel">Action</span></button>
	</div>
</header>


