<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><% if (isOwnProfile) { %>My Profile — Campus Marketplace<% } else { %><%= viewingUser.nickname || viewingUser.name %> — Campus Marketplace<% } %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/profile.css">
  <link rel="stylesheet" href="/css/rating.css">
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>

</head>
<body>
  <%- include('partials/navbar') %>
  <%- include('partials/sidebar') %>

  <%
    // Determine which user we're viewing
    const profileUser = isOwnProfile ? user : viewingUser;
    const isViewingOwn = isOwnProfile;
  %>

  <div class="profile-wrap">
    <div class="profile-header">
      <h1><% if (isViewingOwn) { %>My Profile<% } else { %><%= profileUser.nickname || profileUser.name %>'s Profile<% } %></h1>
    </div>

    <% if (!isViewingOwn) { %>
      <!-- ── PUBLIC PROFILE VIEW ── -->
      <div class="profile-public">
        <!-- User Info Card -->
        <div class="card user-info-card">
          <div class="user-info-header">
            <div class="user-avatar-section">
              <img
                src="<%= profileUser.avatar || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(profileUser.name) + '&background=E8F0FE&color=2563EB&size=200' %>"
                alt="<%= profileUser.name %>"
                class="user-avatar-lg"
              >
              <div class="user-info-text">
                <div class="user-name"><%= profileUser.nickname || profileUser.name %></div>
                <div class="user-uni"><i data-lucide="building-2" style="width:13px;height:13px;display:inline-block;vertical-align:middle;margin-right:4px;"></i><%= profileUser.university || 'No university listed' %></div>
              </div>
            </div>
            <div class="user-stats">
              <div class="stat-box">
                <div class="stat-value" style="display:flex;align-items:center;gap:4px;justify-content:center;">
                  <%- renderStars(profileUser.rating || 5, 14) %>
                  <span style="font-size:14px;font-weight:700;margin-left:2px"><%= (profileUser.rating || 5).toFixed(1) %></span>
                </div>
                <div class="stat-label">Rating</div>
              </div>
              <div class="stat-box">
                <div class="stat-value"><%= profileUser.totalSales || 0 %></div>
                <div class="stat-label">Sales</div>
              </div>
              <div class="stat-box">
                <div class="stat-value"><%= profileUser.ratingCount || 0 %></div>
                <div class="stat-label">Reviews</div>
              </div>
            </div>
          </div>
          <% if (profileUser.bio) { %>
            <div class="user-bio">
              <%= profileUser.bio %>
            </div>
          <% } %>
          <% if (user && !isViewingOwn) { %>
            <button onclick="showReportModal('user', '<%= viewingUser._id %>')" style="width:100%;margin-top:12px;padding:11px;border:1px solid #fca5a5;background:#fff5f5;color:#dc2626;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:all 0.18s;font-family:inherit;">
              🚩 Report this profile
            </button>
          <% } %>
        </div>

        <!-- User Rating Section -->
        <div class="card" style="margin: 20px 0;">
          <div style="font-size: 18px; font-weight: 700; margin-bottom: 16px; color: var(--t1);">User Reviews</div>
          <div id="user-rating-stats-content">Loading...</div>
          <div id="user-rating-dist-content" style="margin-top: 16px;"></div>
          <div id="user-reviews-list" style="margin-top: 20px;"></div>
        </div>

        <!-- Products Grid -->
        <div class="products-section">
          <div class="section-header">
            <h2><i data-lucide="shopping-bag" style="width:18px;height:18px;display:inline-block;vertical-align:middle;margin-right:6px;"></i>Listings</h2>
            <span class="product-count"><%= products.length %> item<%= products.length !== 1 ? 's' : '' %></span>
          </div>

          <% if (products && products.length > 0) { %>
            <div class="products-grid">
              <% 
                const CAT_ICON = {
                  books:        'book-open',
                  electronics:  'monitor',
                  clothing:     'shirt',
                  furniture:    'sofa',
                  'daily-needs':'shopping-bag',
                  sports:       'dumbbell',
                  gaming:       'gamepad-2',
                  other:        'package',
                };
              %>
              <% products.forEach(function(p) { %>
                <a href="/products/<%= p._id %>" class="product-card">
                  <div class="product-image">
                    <% if (p.images && p.images[0]) { %>
                      <img src="<%= p.images[0] %>" alt="<%= p.title %>">
                    <% } else { %>
                      <div class="product-image-placeholder">
                        <i data-lucide="<%= CAT_ICON[p.category] || 'package' %>"></i>
                      </div>
                    <% } %>
                  </div>
                  <div class="product-info">
                    <div class="product-title"><%= p.title %></div>
                    <div class="product-price">
                      <%= new Intl.NumberFormat('vi-VN', { style:'currency', currency:'VND' }).format(p.price) %>
                    </div>
                    <% if (p.status === 'sold') { %>
                      <span class="product-status sold">Sold</span>
                    <% } %>
                  </div>
                </a>
              <% }) %>
            </div>
          <% } else { %>
            <div class="empty-state">
              <i data-lucide="inbox" style="width:48px;height:48px;color:#B0B6CC;"></i>
              <p>This user has no active listings</p>
            </div>
          <% } %>
        </div>
      </div>

    <% } else { %>
      <!-- ── OWN PROFILE VIEW ── -->

      <!-- ── LEFT: Avatar + Stats + Recent products ── -->
      <div style="display:flex;flex-direction:column;gap:20px;">

        <!-- Avatar card -->
        <div class="card avatar-card">
          <div class="avatar-wrap" id="avatar-wrap">
            <img
              src="<%= user.avatar || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) + '&background=E8F0FE&color=2563EB&size=200' %>"
              alt="<%= user.name %>"
              class="avatar-img"
              id="avatar-img"
            >
            <label class="avatar-change-btn" for="avatar-upload-input" title="Change avatar">
              <i data-lucide="camera"></i>
            </label>
            <input type="file" id="avatar-upload-input" style="display:none" accept="image/*">
          </div>
          <div class="avatar-name"><%= user.nickname || user.name %></div>
          <div class="avatar-email"><%= user.email %></div>
          <div class="avatar-hint">
            Avatar is synced from Google.<br>
            Or upload a custom one
            <i data-lucide="arrow-up" style="width:12px;height:12px;display:inline-block;vertical-align:middle;"></i>
          </div>

          <div class="stats-mini">
            <div class="stat-mini">
              <div class="stat-mini-num" style="display:flex;align-items:center;gap:4px;justify-content:center;">
                <%- renderStars(user.rating || 5, 12) %>
                <span style="font-size:13px;font-weight:700;margin-left:2px"><%= (user.rating || 5).toFixed(1) %></span>
              </div>
              <div class="stat-mini-lbl">Rating</div>
            </div>
            <div class="stat-mini">
              <div class="stat-mini-num"><%= user.totalSales || 0 %></div>
              <div class="stat-mini-lbl">Sold</div>
            </div>
            <div class="stat-mini">
              <div class="stat-mini-num"><%= user.ratingCount || 0 %></div>
              <div class="stat-mini-lbl">Reviews</div>
            </div>
          </div>
        </div>

        <!-- Recent products -->
        <div class="card">
          <div class="card-title">
          My Listings
          </div>
          <% if (products && products.length > 0) { %>
            <div class="recent-products">
              <%
                const CAT_ICON = {
                  books:        'book-open',
                  electronics:  'monitor',
                  clothing:     'shirt',
                  furniture:    'sofa',
                  'daily-needs':'shopping-bag',
                  sports:       'dumbbell',
                  gaming:       'gamepad-2',
                  other:        'package',
                };
              %>
              <% products.slice(0, 4).forEach(function(p) { %>
                <a href="/products/<%= p._id %>" class="mini-row" style="text-decoration:none;color:inherit;display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid #F0F1F8;transition:all 0.2s ease;">
                  <div class="mini-thumb">
                    <% if (p.images && p.images[0]) { %>
                      <img src="<%= p.images[0] %>" alt="<%= p.title %>">
                    <% } else { %>
                      <i data-lucide="<%= CAT_ICON[p.category] || 'package' %>" style="width:20px;height:20px;stroke:#8890B0;"></i>
                    <% } %>
                  </div>
                  <div style="flex:1;min-width:0;">
                    <div class="mini-title" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= p.title %></div>
                    <div class="mini-meta">
                      <span class="status-dot dot-<%= p.status %>"></span>
                      <%= p.status === 'active' ? 'Active' : p.status === 'sold' ? 'Sold' : 'Draft' %>
                      ·
                      <i data-lucide="eye"></i> <%= p.views || 0 %>
                    </div>
                  </div>
                  <div class="mini-price">
                    <%= new Intl.NumberFormat('vi-VN', { style:'currency', currency:'VND' }).format(p.price) %>
                  </div>
                </a>
              <% }) %>
            </div>
            <% if (products.length > 4) { %>
              <a href="/my-products" class="see-all">
                See all <%= products.length %> listings
                <i data-lucide="arrow-right" style="width:14px;height:14px;display:inline-block;vertical-align:middle;margin-left:3px;"></i>
              </a>
            <% } %>
          <% } else { %>
            <div class="empty-mini">
              No listings yet.<br>
              <a href="/sell" style="color:#1B5EFF;font-weight:700;">
                Post your first item
                <i data-lucide="arrow-right" style="width:13px;height:13px;display:inline-block;vertical-align:middle;"></i>
              </a>
            </div>
          <% } %>
        </div>

      </div>

      <!-- ── RIGHT: Edit form ── -->
      <div class="card form-section">
        <div class="card-title">
          Edit Profile
        </div>

        <!-- Read-only: từ Google -->
        <div class="form-row">
          <div class="form-group">
            <label>Full name <span style="color:#B0B6CC;font-weight:400;">(from Google)</span></label>
            <input type="text" value="<%= user.name %>" class="readonly" readonly>
          </div>
          <div class="form-group">
            <label>Email <span style="color:#B0B6CC;font-weight:400;">(from Google)</span></label>
            <input type="text" value="<%= user.email %>" class="readonly" readonly>
          </div>
        </div>

        <!-- Editable -->
        <div class="form-row">
          <div class="form-group">
            <label>Display name *</label>
            <input type="text" id="f-nickname"
              value="<%= user.nickname || '' %>"
              placeholder="E.g.: Alex Johnson" maxlength="40">
            <div class="form-hint">Name shown to other users</div>
          </div>
          <div class="form-group">
            <label>Phone number</label>
            <input type="tel" id="f-phone"
              value="<%= user.phone || '' %>"
              placeholder="(555) 123-4567" maxlength="15">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>University / College *</label>
            <input type="text" id="f-university"
              value="<%= user.university || '' %>"
              placeholder="E.g.: MIT" maxlength="80">
          </div>
          <div class="form-group">
            <label>Student ID</label>
            <input type="text" id="f-student-id"
              value="<%= user.studentId || '' %>"
              placeholder="20210001" maxlength="20">
            <div class="form-hint">Optional — helps verify you're a student</div>
          </div>
        </div>

        <div class="form-group">
          <label>Short bio</label>
          <textarea id="f-bio" rows="3" maxlength="200"
            placeholder="E.g.: 3rd-year CS student, buying/selling books and electronics..."><%= user.bio || '' %></textarea>
          <div class="form-hint" id="bio-count"><%= (user.bio || '').length %> / 200</div>
        </div>

        <div style="display:flex;align-items:center;gap:12px;padding-top:4px;">
          <button class="btn-save" id="btn-save" onclick="saveProfile()">
        
            Save changes
          </button>
          <span id="save-status" style="font-size:13px;color:#8890B0;"></span>
        </div>
        </div>

      </div>
    <% } %>
  </div>

  <div id="toast-wrap"></div>

  <!-- Report Modal -->
  <div id="report-modal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:999;align-items:center;justify-content:center;flex-direction:column;">
    <div style="background:#fff;border-radius:16px;padding:24px;max-width:450px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.3);">
      <div style="font-size:18px;font-weight:700;margin-bottom:16px;">Report this item</div>
      <div style="color:#666;font-size:14px;margin-bottom:20px;">Help us keep Campus safe by reporting inappropriate content.</div>
      
      <div style="margin-bottom:16px;">
        <label style="display:block;font-size:13px;font-weight:600;margin-bottom:6px;">Reason *</label>
        <select id="report-reason" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:6px;font-size:14px;font-family:inherit;">
          <option value="">Select a reason...</option>
          <option value="inappropriate-content">Inappropriate content</option>
          <option value="offensive-language">Offensive language</option>
          <option value="fraud-scam">Fraud/Scam</option>
          <option value="counterfeit-item">Counterfeit item</option>
          <option value="damaged-item">Damaged/Missing item</option>
          <option value="misleading-description">Misleading description</option>
          <option value="fake-account">Fake account</option>
          <option value="suspicious-behavior">Suspicious behavior</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div style="margin-bottom:20px;">
        <label style="display:block;font-size:13px;font-weight:600;margin-bottom:6px;">Description</label>
        <textarea id="report-content" maxlength="500" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:6px;font-size:14px;font-family:inherit;resize:vertical;min-height:100px;" placeholder="Provide details (optional)..."></textarea>
        <div style="font-size:12px;color:#999;margin-top:4px;text-align:right;"><span id="report-char-count">0</span>/500</div>
      </div>

      <div style="display:flex;gap:10px;">
        <button onclick="closeReportModal()" style="flex:1;padding:11px;border:1px solid #ddd;background:#fff;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:all 0.18s;">Cancel</button>
        <button onclick="submitReport()" style="flex:1;padding:11px;border:none;background:#dc2626;color:#fff;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:all 0.18s;">Submit Report</button>
      </div>
    </div>
  </div>

  <script>
    // Init Lucide static icons
    lucide.createIcons();

    <% if (isOwnProfile) { %>
    // ── Bio counter ──────────────────────────────────────
    document.getElementById('f-bio').addEventListener('input', function () {
      document.getElementById('bio-count').textContent = this.value.length + ' / 200';
    });

    // ── Save profile ─────────────────────────────────────
    window.saveProfile = async function () {
      const nickname   = document.getElementById('f-nickname').value.trim();
      const university = document.getElementById('f-university').value.trim();

      if (!nickname) {
        document.getElementById('f-nickname').style.borderColor = '#E84040';
        toast('Display name is required', 'err');
        return;
      }
      if (!university) {
        document.getElementById('f-university').style.borderColor = '#E84040';
        toast('University is required', 'err');
        return;
      }

      const btn = document.getElementById('btn-save');
      btn.disabled = true;
      btn.innerHTML =
        '<svg width="16" height="16" viewBox="0 0 24 24" style="animation:spin 0.7s linear infinite;display:inline-block;vertical-align:middle;margin-right:6px;">' +
        '<circle cx="12" cy="12" r="10" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2"/>' +
        '<path d="M12 2a10 10 0 0 1 10 10" fill="none" stroke="#fff" stroke-width="2"/></svg> Saving...';

      try {
        const res = await fetch('/api/auth/profile', {
          method: 'PATCH',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            nickname,
            university,
            phone:      document.getElementById('f-phone').value.trim(),
            studentId:  document.getElementById('f-student-id').value.trim(),
            bio:        document.getElementById('f-bio').value.trim(),
            profileComplete: true,
          }),
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.message || 'Save failed');

        toast('Profile saved!', 'ok');
        document.getElementById('save-status').textContent = 'Last saved: ' + new Date().toLocaleTimeString();
        document.querySelector('.avatar-name').textContent = data.data.nickname || data.data.name;

      } catch (err) {
        toast(err.message || 'Failed to save', 'err');
      } finally {
        btn.disabled = false;
        btn.innerHTML =
          '<i data-lucide="check" style="width:16px;height:16px;display:inline-block;vertical-align:middle;margin-right:6px;"></i> Save changes';
        lucide.createIcons({ nodes: [document.getElementById('btn-save')] });
      }
    };

    // ── Avatar upload ─────────────────────────────────────
    document.getElementById('avatar-upload-input').addEventListener('change', async function () {
      const file = this.files[0];
      if (!file) return;
      if (file.size > 5 * 1024 * 1024) { toast('Image must be under 5MB', 'err'); return; }

      const wrap = document.getElementById('avatar-wrap');
      wrap.classList.add('avatar-uploading');

      try {
        const formData = new FormData();
        formData.append('image', file);

        const res  = await fetch('/api/upload/avatar', {
          method: 'POST',
          credentials: 'include',
          body: formData,
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.message || 'Upload failed');

        document.getElementById('avatar-img').src = data.url;

        await fetch('/api/auth/profile', {
          method: 'PATCH',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ avatar: data.url }),
        });

        toast('Avatar updated!', 'ok');
      } catch (err) {
        toast(err.message || 'Upload failed', 'err');
      } finally {
        wrap.classList.remove('avatar-uploading');
        this.value = '';
      }
    });

    // ── Reset border on focus ─────────────────────────────
    ['f-nickname', 'f-university'].forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        el.addEventListener('focus', function () {
          this.style.borderColor = '';
        });
      }
    });
    <% } %>

    // ── Toast function (available everywhere) ───────────────────────────
    function toast(msg, type) {
      const c = document.getElementById('toast-wrap');
      const t = document.createElement('div');
      t.className = 'toast ' + (type || 'ok');
      const icon = type === 'err'
        ? '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="flex-shrink:0"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>'
        : '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="flex-shrink:0"><polyline points="20 6 9 17 4 12"/></svg>';
      t.style.cssText = 'display:flex;align-items:center;gap:8px;';
      t.innerHTML = icon + msg;
      c.appendChild(t);
      setTimeout(() => { t.style.opacity='0'; t.style.transition='opacity 0.3s'; setTimeout(()=>t.remove(), 300); }, 3000);
    }

    // ── Report Modal ──────────────────────────────────────────────────────
    let reportTargetType = '';
    let reportTargetId = '';

    window.showReportModal = function (targetType, targetId) {
      reportTargetType = targetType;
      reportTargetId = targetId;
      document.getElementById('report-modal').style.display = 'flex';
      document.getElementById('report-reason').value = '';
      document.getElementById('report-content').value = '';
      document.getElementById('report-char-count').textContent = '0';
    };

    window.closeReportModal = function () {
      document.getElementById('report-modal').style.display = 'none';
    };

    window.submitReport = async function () {
      const reason = document.getElementById('report-reason').value;
      const content = document.getElementById('report-content').value;

      if (!reason) {
        toast('Please select a reason', 'err');
        return;
      }

      try {
        const res = await fetch('/api/report', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            targetType: reportTargetType,
            targetId: reportTargetId,
            reason,
            content
          })
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.message || 'Failed to submit report');

        toast('Report submitted. Thank you!', 'ok');
        closeReportModal();
      } catch (err) {
        toast(err.message, 'err');
      }
    };

    // Character counter for report textarea
    document.addEventListener('DOMContentLoaded', () => {
      const textarea = document.getElementById('report-content');
      if (textarea) {
        textarea.addEventListener('input', () => {
          document.getElementById('report-char-count').textContent = textarea.value.length;
        });
      }
    });
  </script>
  <script src="/js/rating.js"></script>
  <script>
    // Load user ratings if viewing non-own profile
    <% if (!isViewingOwn) { %>
      document.addEventListener('DOMContentLoaded', async () => {
        const userId = '<%= viewingUser._id %>';
        if (userId && document.getElementById('user-review-list')) {
          loadRatings('user', userId, 'user-reviews-list');
          loadRatingStats('user', userId, 'user-rating-stats-content');
        }
      });
    <% } %>
  </script>
</body>
</html>