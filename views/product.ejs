<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.title %> — Campus Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/product.css">
  <style>
    .similar-section { max-width:1100px; margin:0 auto; padding:0 24px 60px; }
    .similar-title { font-size:20px; font-weight:800; color:#0D0F1A; margin-bottom:20px; }
    .products-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(220px,1fr)); gap:20px; }
    .product-card { background:#fff; border-radius:16px; border:1px solid #E4E7F2; overflow:hidden; transition:all 0.25s; cursor:pointer; text-decoration:none; color:inherit; display:block; }
    @media (min-width: 901px) {
      body.has-sidebar > .similar-section { margin-left: var(--sb-w); }
    }
    .product-card:hover { transform:translateY(-4px); box-shadow:0 12px 24px rgba(13,15,26,0.08); border-color:#1B5EFF; }
    .product-img-placeholder { width:100%; aspect-ratio:4/3; display:flex; align-items:center; justify-content:center; font-size:48px; background:linear-gradient(135deg,#EBF0FF,#E4E7F2); }
    .product-body { padding:16px; }
    .product-category { font-size:11px; font-weight:600; color:#1B5EFF; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px; }
    .product-name { font-size:15px; font-weight:700; color:#0D0F1A; margin-bottom:6px; line-height:1.4; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
    .product-footer { display:flex; align-items:center; justify-content:space-between; }
    .product-price { font-size:18px; font-weight:800; color:#1B5EFF; }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>
  <%- include('partials/sidebar') %>

  <%
    const p         = product;
    const seller    = p.seller || {};
    const isOwner   = user && (String(p.seller && p.seller._id ? p.seller._id : p.seller) === String(user && user._id));
    const isSold    = p.status === 'sold';
    const CAT_LABEL = { books:'Books', electronics:'Electronics', clothing:'Clothing', furniture:'Furniture', 'daily-needs':'Daily needs', sports:'Sports', gaming:'Gaming', other:'Other' };
    const CAT_EMOJI = { books:'📚', electronics:'💻', clothing:'👕', furniture:'🛋️', 'daily-needs':'🧴', sports:'⚽', gaming:'🎮', other:'📦' };
    const COND_INFO = { new:['✨','New','badge-new'], 'like-new':['💎','Like new','badge-like-new'], good:['👍','Good','badge-good'], fair:['🔧','Fair','badge-fair'] };
    const cond      = COND_INFO[p.condition] || ['📦', p.condition, 'badge-new'];
    const sellerName = seller.nickname || seller.name || 'Anonymous';
    const joinDate  = seller.createdAt ? new Date(seller.createdAt).toLocaleDateString('en-US', { month:'long', year:'numeric' }) : '';

    function timeAgo(dateStr) {
      const diff = Date.now() - new Date(dateStr).getTime();
      const m = Math.floor(diff / 60000);
      if (m < 1)  return 'Just now';
      if (m < 60) return m + ' minute' + (m > 1 ? 's' : '') + ' ago';
      const h = Math.floor(m / 60);
      if (h < 24) return h + ' hour' + (h > 1 ? 's' : '') + ' ago';
      const d = Math.floor(h / 24);
      if (d < 30) return d + ' day' + (d > 1 ? 's' : '') + ' ago';
      const mo = Math.floor(d / 30);
      return mo + ' month' + (mo > 1 ? 's' : '') + ' ago';
    }
  %>

  <div class="detail-layout">

    <!-- Gallery -->
    <div class="gallery">
      <div class="gallery-main">
        <% if (p.images && p.images[0]) { %>
          <img id="main-img" src="<%= p.images[0] %>" alt="<%= p.title %>">
        <% } else { %>
          <div style="font-size:80px; display:flex; align-items:center; justify-content:center; color:#1B5EFF;">
            <svg width="88" height="88" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:block"><path d="M21 16V8a2 2 0 0 0-1-1.73L13 3l-7 3.27A2 2 0 0 0 5 8v8a2 2 0 0 0 1 1.73L11 21l7-3.27A2 2 0 0 0 21 16z"/><path d="M12 3v10"/></svg>
          </div>
        <% } %>
      </div>
      <% if (p.images && p.images.length > 1) { %>
        <div class="gallery-thumbs">
          <% p.images.forEach(function(url, i) { %>
            <div class="gallery-thumb <%= i === 0 ? 'active' : '' %>" onclick="setImg(<%= i %>)">
              <img src="<%= url %>" alt="image <%= i+1 %>">
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Right column -->
    <div class="info-section">

      <!-- CTA card -->
      <div class="cta-card">
        <div class="product-badges">
          <span class="badge badge-cat"><%= CAT_LABEL[p.category] || p.category %></span>
          <span class="badge <%= cond[2] %>"><%= cond[0] %> <%= cond[1] %></span>
          <% if (isSold) { %><span class="badge badge-sold">Sold</span><% } %>
        </div>
        <div class="product-title"><%= p.title %></div>
        <div class="cta-price">
          <%= new Intl.NumberFormat('vi-VN', { style:'currency', currency:'VND' }).format(p.price) %>
        </div>
        <div class="product-meta" style="margin-bottom:16px;">
          <span><%= p.views || 0 %> views</span>
          <span><span id="interested-count"><%= p.interested || 0 %></span> interested</span>
          <span><%= timeAgo(p.createdAt) %></span>
        </div>

        <% if (isSold) { %>
          <div class="sold-overlay">🔒 This item has been sold</div>
        <% } else if (isOwner) { %>
          <div class="owner-actions">
            <button class="btn-edit" onclick="window.location.href='/sell?id=<%= p._id %>'">✏️ Edit listing</button>
            <button class="btn-mark-sold" onclick="markSold()">✓ Mark as sold</button>
            <button class="btn-delete" onclick="deleteProduct()">🗑</button>
          </div>
        <% } else { %>
          <% if (user) { %>
            <button class="btn-contact" id="btn-msg-seller" onclick="initChat()">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
              Message seller
            </button>
          <% } else { %>
            <a href="/login" class="btn-contact">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
              Sign in to message seller
            </a>
          <% } %>
          <button class="btn-interested" id="btn-interested" onclick="toggleInterested()">
            <span id="heart-icon">🤍</span>
            Interested <span id="int-count">(<%= p.interested || 0 %>)</span>
          </button>
        <% } %>
      </div>

      <!-- Description -->
      <div>
        <div class="section-title">Product description</div>
        <p class="product-desc"><%= p.description %></p>
      </div>

      <!-- Location -->
      <% if (p.location && p.location.address) { %>
        <div>
          <div class="section-title">Pickup location</div>
          <div class="location-chip">📍 <%= p.location.address %></div>
        </div>
      <% } %>

      <!-- Seller -->
      <div>
        <div class="section-title">Seller</div>
        <div class="seller-card">
          <div class="seller-row">
            <div class="seller-avatar">
              <% if (seller.avatar) { %>
                <img src="<%= seller.avatar %>" alt="<%= sellerName %>">
              <% } else { %>
                <span><%= (sellerName[0] || '?').toUpperCase() %></span>
              <% } %>
            </div>
            <div>
              <div class="seller-name"><%= sellerName %></div>
              <div class="seller-uni">
                <%= seller.university || '' %><%= joinDate ? ' · Joined ' + joinDate : '' %>
              </div>
            </div>
          </div>
          <div class="seller-stats">
            <div class="stat-item"><div class="stat-num">⭐ <%= (seller.rating || 5).toFixed(1) %></div><div class="stat-lbl">Rating</div></div>
            <div class="stat-item"><div class="stat-num"><%= seller.totalSales || 0 %></div><div class="stat-lbl">Sold</div></div>
            <div class="stat-item"><div class="stat-num"><%= seller.ratingCount || 0 %></div><div class="stat-lbl">Reviews</div></div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <% if (typeof relatedProducts !== 'undefined' && relatedProducts.length > 0) { %>
    <div class="similar-section">
      <div class="similar-title">Similar Listings</div>
      <div class="products-grid">
        <% relatedProducts.forEach(function(rp) { %>
          <a href="/products/<%= rp._id %>" class="product-card">
            <div class="product-img-placeholder">
              <% if (rp.images && rp.images[0]) { %>
                <img src="<%= rp.images[0] %>" style="width:100%;height:100%;object-fit:cover;">
              <% } else { %>
                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#1B5EFF;">
                  <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73L13 3l-7 3.27A2 2 0 0 0 5 8v8a2 2 0 0 0 1 1.73L11 21l7-3.27A2 2 0 0 0 21 16z"/><path d="M12 3v10"/></svg>
                </div>
              <% } %>
            </div>
            <div class="product-body">
              <div class="product-category"><%= CAT_LABEL[rp.category] || rp.category %></div>
              <div class="product-name"><%= rp.title %></div>
              <div class="product-footer">
                <div class="product-price"><%= new Intl.NumberFormat('vi-VN',{style:'currency',currency:'VND'}).format(rp.price) %></div>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  <% } %>

  <div id="toast-wrap"></div>

  <!-- ── Fixed bottom buy bar ── -->
  <% if (!isSold && !isOwner) { %>
  <div class="buy-bar" id="buy-bar">
    <div class="buy-bar-price">
      <%= new Intl.NumberFormat('vi-VN', { style:'currency', currency:'VND' }).format(p.price) %>
    </div>
    <div class="buy-bar-actions">
      <button class="buy-bar-buy" onclick="goCheckout()">
  
        Buy now
      </button>
    </div>
  </div>
  <style>
    body { padding-bottom: 80px; }
    .buy-bar {
      position: fixed; bottom: 0; left: var(--sb-w); right: 0; z-index: 200;
      background: #fff; border-top: 1px solid #E4E7F2;
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 24px; box-shadow: 0 -4px 24px rgba(13,15,26,0.10); gap: 16px;
    }
    .buy-bar-price { font-size: 20px; font-weight: 900; color: #1B5EFF; white-space: nowrap; }
    .buy-bar-actions { display: flex; gap: 10px; align-items: center; }
    .buy-bar-cart {
      display: flex; align-items: center; gap: 6px;
      padding: 11px 20px; border: 2px solid #1B5EFF; border-radius: 12px;
      background: #fff; color: #1B5EFF; font-size: 14px; font-weight: 700;
      cursor: pointer; transition: all 0.18s; font-family: inherit;
    }
    .buy-bar-cart:hover { background: #EBF0FF; }
    .buy-bar-buy {
      display: flex; align-items: center; gap: 6px;
      padding: 11px 28px; border: none; border-radius: 12px;
      background: linear-gradient(135deg, #1B5EFF, #5B8AFF); color: #fff;
      font-size: 14px; font-weight: 700; cursor: pointer; transition: all 0.18s;
      font-family: inherit; box-shadow: 0 4px 14px rgba(27,94,255,0.35);
    }
    .buy-bar-buy:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(27,94,255,0.45); }
    .buy-bar-buy:active { transform: translateY(0); }
  </style>
  <style>
    /* Ensure buy bar doesn't overlap the left sidebar on wide screens */
    @media (min-width: 901px) {
      .buy-bar { width: calc(100% - var(--sb-w)); }
    }
    /* On small screens where sidebar is hidden, full-width buy bar */
    @media (max-width: 900px) {
      .buy-bar { left: 0; width: 100%; }
      body { padding-bottom: 80px; }
    }
  </style>
  <% } %>

  <script>
    const PRODUCT_ID = '<%= p._id %>';
    const IS_AUTH    = <%= !!user %>;
    const IMAGES     = <%- JSON.stringify(p.images || []) %>;
    let interestedState = false;

    // Product metadata — truyền sang /messages để hiện banner context
    const PRODUCT_META = {
      id:    PRODUCT_ID,
      title: <%- JSON.stringify(p.title) %>,
      price: <%- JSON.stringify(new Intl.NumberFormat('vi-VN', { style:'currency', currency:'VND' }).format(p.price)) %>,
      image: <%- JSON.stringify((p.images && p.images[0]) || '') %>,
      url:   '/products/' + PRODUCT_ID
    };

    // ── Gallery ──────────────────────────────────────────────────────────
    window.setImg = function (i) {
      const main = document.getElementById('main-img');
      if (main && IMAGES[i]) main.src = IMAGES[i];
      document.querySelectorAll('.gallery-thumb').forEach((t, j) => t.classList.toggle('active', j === i));
    };

    // ── Interested ───────────────────────────────────────────────────────
    window.toggleInterested = async function () {
      if (!IS_AUTH) { toast('Please sign in to mark interest', 'err'); return; }
      interestedState = !interestedState;
      try {
        const res  = await fetch('/api/products/' + PRODUCT_ID + '/interested', { method: 'POST', credentials: 'include' });
        const data = await res.json();
        document.getElementById('heart-icon').textContent = interestedState ? '❤️' : '🤍';
        document.getElementById('int-count').textContent  = '(' + data.interested + ')';
        document.getElementById('btn-interested').classList.toggle('active', interestedState);
      } catch { interestedState = !interestedState; }
    };

    // ── Chat — redirect to /messages with conversation pre-selected ──────
    window.initChat = async function () {
      const btn = document.getElementById('btn-msg-seller');
      if (btn) { btn.disabled = true; btn.style.opacity = '0.7'; }
      try {
        const res  = await fetch('/api/chat/init', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId: PRODUCT_ID }),
          credentials: 'include'
        });
        const json = await res.json();
        if (json.success) {
          window.location.href = '/messages?id=' + json.conversationId
            + '&product=' + encodeURIComponent(JSON.stringify(PRODUCT_META));
        } else {
          toast(json.message, 'err');
          if (btn) { btn.disabled = false; btn.style.opacity = '1'; }
        }
      } catch (err) {
        toast(err.message, 'err');
        if (btn) { btn.disabled = false; btn.style.opacity = '1'; }
      }
    };

    // ── Owner: mark sold ─────────────────────────────────────────────────
    window.markSold = async function () {
      if (!confirm('Mark this item as sold?')) return;
      try {
        const res = await fetch('/api/products/' + PRODUCT_ID, {
          method: 'PATCH', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: 'sold' })
        });
        if (!res.ok) throw new Error((await res.json()).message);
        toast('Status updated!', 'ok');
        setTimeout(() => location.reload(), 1000);
      } catch (err) { toast(err.message, 'err'); }
    };

    // ── Owner: delete ────────────────────────────────────────────────────
    window.deleteProduct = async function () {
      if (!confirm('Delete this listing? This action cannot be undone.')) return;
      try {
        const res = await fetch('/api/products/' + PRODUCT_ID, { method: 'DELETE', credentials: 'include' });
        if (!res.ok) throw new Error((await res.json()).message);
        toast('Listing deleted', 'ok');
        setTimeout(() => window.location.href = '/', 1200);
      } catch (err) { toast(err.message, 'err'); }
    };


    // ── Buy Now — go to checkout ─────────────────────────────────────────
    window.goCheckout = function () {
      if (!IS_AUTH) { toast('Please sign in to purchase', 'err'); return; }
      window.location.href = '/checkout/' + PRODUCT_ID;
    };
    function toast(msg, type) {
      const c = document.getElementById('toast-wrap');
      const t = document.createElement('div');
      t.className = 'toast ' + (type || 'ok');
      t.innerHTML = (type === 'err' ? '✕' : '✓') + ' ' + msg;
      c.appendChild(t);
      setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; setTimeout(() => t.remove(), 300); }, 3000);
    }
  </script>
</body>
</html>
