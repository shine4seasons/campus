<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>404 — Campus Marketplace</title>
  <link rel="stylesheet" href="/css/main.css">
  <style>
    .not-found { text-align:center; padding:100px 20px; }
    .not-found .icon  { font-size:64px; margin-bottom:16px; }
    .not-found h1     { font-size:24px; font-weight:900; color:#0D0F1A; margin-bottom:8px; }
    .not-found p      { color:#8890B0; margin-bottom:24px; }
    .not-found a      { display:inline-block; padding:12px 28px; background:#1B5EFF; color:#fff; border-radius:12px; font-weight:700; text-decoration:none; }
    .not-found a:hover { background:#1348D6; }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>
  <%- include('partials/sidebar') %>
  <div class="not-found">
    <div class="icon">🔍</div>
    <h1>Page not found</h1>
    <p>The page you're looking for doesn't exist or has been removed.</p>
    <a href="/">← Back to homepage</a>
  </div>
</body>
</html>
