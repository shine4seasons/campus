<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Seller Dashboard — Campus Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link
    href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/rating.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
</head>

<body>
  <%- include('partials/navbar') %>
    <%- include('partials/sidebar') %>


      <main class="main">

        <div class="content">

          <!-- ── SECTION: Dashboard ── -->
          <section class="section active" id="sDash">
            <div class="stat-grid">
              <div class="stat-card">
                <div class="stat-top">
                  <div>
                    <div class="stat-label">Active listings</div>
                  </div>
                  <div class="stat-icon" style="background:#dcfce7;color:#16a34a">
                    <svg viewBox="0 0 24 24">
                      <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                      <line x1="3" y1="6" x2="21" y2="6" />
                    </svg>
                  </div>
                </div>
                <div class="stat-val"><%= stats.activeListings %></div>
                <div class="stat-delta delta-neu">Total active items</div>
              </div>
              <div class="stat-card">
                <div class="stat-top">
                  <div>
                    <div class="stat-label">Orders awaiting confirmation</div>
                  </div>
                  <div class="stat-icon" style="background:#fef3c7;color:#d97706">
                    <svg viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="10" />
                      <polyline points="12 6 12 12 16 14" />
                    </svg>
                  </div>
                </div>
                <div class="stat-val" style="color:#d97706"><%= stats.pendingOrders %></div>
                <div class="stat-delta" style="color:#d97706">need confirmation</div>
              </div>
              <div class="stat-card">
                <div class="stat-top">
                  <div>
                    <div class="stat-label">This month's revenue</div>
                  </div>
                  <div class="stat-icon" style="background:#dbeafe;color:#2563eb">
                    <svg viewBox="0 0 24 24">
                      <line x1="12" y1="1" x2="12" y2="23" />
                      <path d="M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6" />
                    </svg>
                  </div>
                </div>
                <div class="stat-val">
                  <%= (stats.monthRevenue >= 1000000) ? (stats.monthRevenue / 1000000).toFixed(1) + 'M ₫' : new Intl.NumberFormat('vi-VN').format(stats.monthRevenue) + ' ₫' %>
                </div>
                <div class="stat-delta delta-neu">Earned this month</div>
              </div>
              <div class="stat-card">
                <div class="stat-top">
                  <div>
                    <div class="stat-label">Avg. rating</div>
                  </div>
                  <div class="stat-icon" style="background:#fef3c7;color:#d97706">
                    <svg viewBox="0 0 24 24">
                      <polygon
                        points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                  </div>
                </div>
                <div class="stat-val" style="display:flex;align-items:center;gap:4px">
                  <%- renderStars(user.rating || 5, 16) %>
                    <span style="font-size:18px;font-weight:800;margin-left:2px">
                      <%= (user.rating || 5).toFixed(1) %>
                    </span>
                </div>
                <div class="stat-delta delta-neu">Based on <%= user.ratingCount || 0 %> reviews</div>
              </div>
            </div>

            <% if (stats.pendingOrders > 0) { %>
            <div class="alert-box alert-info" style="margin-bottom:18px">
              <svg viewBox="0 0 24 24" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
              </svg>
              <div class="alert-box-text">You have <%= stats.pendingOrders %> order<%= stats.pendingOrders > 1 ? 's' : '' %> awaiting confirmation. Please confirm within 24 hours to
                avoid automatic cancellation.</div>
            </div>
            <% } %>

            <div class="quick-grid">
              <div class="quick-card" onclick="window.location.href='/my-products'">
                <div class="qc-icon" style="background:#dbeafe;color:#2563eb">
                  <svg viewBox="0 0 24 24">
                    <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                    <line x1="3" y1="6" x2="21" y2="6" />
                  </svg>
                </div>
                <div class="qc-body">
                  <div class="qc-label">Manage listings</div>
                  <div class="qc-sub"><%= stats.activeListings %> active · <%= stats.totalSold %> sold</div>
                </div>
              </div>
              <div class="quick-card" onclick="window.location.href='/orders-seller'">
                <div class="qc-icon" style="background:#fef3c7;color:#d97706">
                  <svg viewBox="0 0 24 24">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                  </svg>
                </div>
                <div class="qc-body">
                  <div class="qc-label">View orders</div>
                  <div class="qc-sub"><%= stats.pendingOrders %> order<%= stats.pendingOrders > 1 ? 's' : '' %> awaiting confirmation</div>
                </div>
              </div>
              <div class="quick-card" onclick="window.location.href='/sell'">
                <div class="qc-icon" style="background:#dcfce7;color:#16a34a">
                  <svg viewBox="0 0 24 24">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                  </svg>
                </div>
                <div class="qc-body">
                  <div class="qc-label">Post a new listing</div>
                  <div class="qc-sub">Create a new listing</div>
                </div>
              </div>
            </div>

            <div class="charts-row">
              <div class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">My revenue — 2026</div>
                    <div class="card-sub">By month (₫ thousands)</div>
                  </div>
                </div>
                <div style="position:relative;height:200px"><canvas id="cSellerRev"></canvas></div>
              </div>
              <div class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Categories sold</div>
                    <div class="card-sub">Distribution</div>
                  </div>
                </div>
                <div style="position:relative;height:160px;margin-bottom:12px"><canvas id="cSellerCat"></canvas></div>
                <div class="legend" style="flex-direction:column;gap:7px" id="sCatLegend">
                  <span class="leg-item"><span class="leg-dot" style="background:#2563eb"></span>No data</span>
                </div>
              </div>
            </div>
          </section>

          <!-- ── SECTION: Orders, Listings, Revenue are split into separate pages ── -->
          <!-- See: dashboard-listings.ejs, dashboard-orders.ejs, dashboard-revenue.ejs -->

          <!-- ── SECTION: Messages ── -->
          <section class="section" id="sMessages">
            <div class="alert-box alert-info" style="margin-bottom:16px">
              <svg viewBox="0 0 24 24" stroke-width="2">
                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
              </svg>
              <div class="alert-box-text">You have 4 unread messages. <a href="/messages"
                  style="color:var(--blue);font-weight:600">Open inbox →</a></div>
            </div>
            <div class="two-col">
              <div class="tbl-wrap" style="margin-bottom:0">
                <div class="tbl-toolbar">
                  <div>
                    <div class="tbl-title">Recent conversations</div>
                  </div>
                </div>
                <div style="padding: 0 20px">
                  <div class="list-item">
                    <div class="li-avatar" style="background:#dbeafe;color:#1d4ed8">HA</div>
                    <div class="li-info">
                      <div class="li-name">Hùng Anh<span
                          style="font-size:11px;color:var(--t2);font-weight:400;margin-left:8px">2 phút trước</span>
                      </div>
                      <div class="li-sub">Casio FX-580 — Anh ơi mai giao được không?</div>
                    </div><span class="nav-badge" style="font-size:10px">2</span>
                  </div>
                  <div class="list-item">
                    <div class="li-avatar" style="background:#dcfce7;color:#15803d">LC</div>
                    <div class="li-info">
                      <div class="li-name">Lan Chi<span
                          style="font-size:11px;color:var(--t2);font-weight:400;margin-left:8px">1 giờ trước</span>
                      </div>
                      <div class="li-sub">Balo — Địa chỉ giao hàng của em là...</div>
                    </div><span class="nav-badge" style="font-size:10px">1</span>
                  </div>
                  <div class="list-item">
                    <div class="li-avatar" style="background:#fef3c7;color:#b45309">TA</div>
                    <div class="li-info">
                      <div class="li-name">Tú Anh<span
                          style="font-size:11px;color:var(--t2);font-weight:400;margin-left:8px">Hôm qua</span></div>
                      <div class="li-sub">Đã nhận hàng rồi, cảm ơn anh</div>
                    </div>
                  </div>
                  <div class="list-item">
                    <div class="li-avatar" style="background:#ede9fe;color:#6d28d9">HY</div>
                    <div class="li-info">
                      <div class="li-name">Hải Yến<span
                          style="font-size:11px;color:var(--t2);font-weight:400;margin-left:8px">2 ngày trước</span>
                      </div>
                      <div class="li-sub">Giáo trình — Ok anh, em nhận hàng rồi</div>
                    </div><span class="nav-badge" style="font-size:10px">1</span>
                  </div>
                </div>
                <div style="padding:12px 20px;border-top:1px solid var(--border)">
                  <a href="/messages" class="btn btn-primary" style="display:inline-flex">Open full inbox →</a>
                </div>
              </div>
              <div class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Chat stats</div>
                  </div>
                </div>
                <div class="prog-row">
                  <div class="prog-item">
                    <div class="prog-meta"><span class="prog-label">Response rate</span><span
                        class="prog-val">95%</span></div>
                    <div class="prog-bar">
                      <div class="prog-fill" style="width:95%;background:#22c55e"></div>
                    </div>
                  </div>
                  <div class="prog-item">
                    <div class="prog-meta"><span class="prog-label">Response within 1 hour</span><span
                        class="prog-val">82%</span></div>
                    <div class="prog-bar">
                      <div class="prog-fill" style="width:82%;background:#2563eb"></div>
                    </div>
                  </div>
                </div>
                <div style="margin-top:20px;display:flex;flex-direction:column;gap:8px;font-size:13px">
                  <div style="display:flex;justify-content:space-between"><span style="color:var(--t2)">Total
                      conversations</span><span style="font-weight:600">34</span></div>
                  <div style="display:flex;justify-content:space-between"><span
                      style="color:var(--t2)">Unread</span><span style="font-weight:600;color:#d97706">4</span></div>
                  <div style="display:flex;justify-content:space-between"><span style="color:var(--t2)">Avg. response
                      time</span><span style="font-weight:600">24 min</span></div>
                </div>
              </div>
            </div>
          </section>

          <!-- ── SECTION: Profile ── -->
          <section class="section" id="sProfile">
            <div class="two-col">
              <div class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Profile information</div>
                    <div class="card-sub">Displayed on your seller page</div>
                  </div>
                </div>
                <div class="form-grid">
                  <div class="form-row">
                    <div class="form-group"><label class="form-label">Full name</label><input class="form-input"
                        value="Trần Ngọc"></div>
                    <div class="form-group"><label class="form-label">Nickname</label><input class="form-input"
                        value="ngoc.t"></div>
                  </div>
                  <div class="form-row">
                    <div class="form-group"><label class="form-label">Phone number</label><input class="form-input"
                        value="0912 345 678" type="tel"></div>
                    <div class="form-group"><label class="form-label">University</label><input class="form-input"
                        value="HUST"></div>
                  </div>
                  <div class="form-group"><label class="form-label">Student ID</label><input class="form-input"
                      value="20200001"></div>
                  <div class="form-group"><label class="form-label">About you</label><textarea
                      class="form-textarea">Selling electronics and textbooks at HUST. Fast, reliable transactions. Contact me for support.</textarea>
                  </div>
                  <div style="display:flex;gap:10px">
                    <button class="btn btn-primary" onclick="showToast('Profile saved','ok')">Save changes</button>
                    <button class="btn btn-outline" onclick="showToast('Edit canceled','info')">Cancel</button>
                  </div>
                </div>
              </div>

              <div style="display:flex;flex-direction:column;gap:16px">
                <div class="card">
                  <div class="card-head">
                    <div>
                      <div class="card-title">Seller stats</div>
                    </div>
                  </div>
                  <div style="display:flex;flex-direction:column;gap:4px">
                    <div class="list-item">
                      <div class="li-info">
                        <div class="li-name">Rating Score</div>
                        <div class="li-sub">Based on <%= user.ratingCount || 0 %> reviews</div>
                      </div>
                      <div style="display:flex;align-items:center;gap:4px">
                        <%- renderStars(user.rating || 5, 14) %>
                          <span style="font-size:18px;font-weight:800;color:#d97706;margin-left:2px">
                            <%= (user.rating || 5).toFixed(1) %>
                          </span>
                      </div>
                    </div>
                    <div class="list-item">
                      <div class="li-info">
                        <div class="li-name">Total sold</div>
                      </div>
                      <div class="li-val"><%= user.totalSales || 0 %> items</div>
                    </div>
                    <div class="list-item">
                      <div class="li-info">
                        <div class="li-name">Total revenue</div>
                      </div>
                      <div class="li-val" style="color:#16a34a">
                        <%= (stats.totalRevenue >= 1000000) ? (stats.totalRevenue / 1000000).toFixed(1) + 'M ₫' : new Intl.NumberFormat('vi-VN').format(stats.totalRevenue) + ' ₫' %>
                      </div>
                    </div>
                    <div class="list-item">
                      <div class="li-info">
                        <div class="li-name">Member since</div>
                      </div>
                      <div class="li-val"><%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %></div>
                    </div>
                    <div class="list-item">
                      <div class="li-info">
                        <div class="li-name">Profile status</div>
                      </div><span class="badge badge-active"><%= user.profileComplete ? 'Complete' : 'Pending' %></span>
                    </div>
                  </div>
                </div>

                <div class="card">
                  <div class="card-head">
                    <div>
                      <div class="card-title">Recent reviews</div>
                    </div><a class="card-action" href="#">View all</a>
                  </div>
                  <div id="recentReviewsList">
                    <% if (recentRatings && recentRatings.length > 0) { %>
                      <% recentRatings.forEach(r => { %>
                        <div class="review-item">
                          <div class="review-top">
                            <span class="review-author"><%= r.rater?.nickname || r.rater?.name || 'Anonymous' %></span>
                            <span class="review-stars">
                              <% for(let i=0; i<5; i++) { %>
                                <%= i < r.score ? '★' : '☆' %>
                              <% } %>
                            </span>
                          </div>
                          <div class="review-text"><%= r.comment || '(No comment)' %></div>
                          <div class="review-date"><%= new Date(r.createdAt).toLocaleDateString() %></div>
                        </div>
                      <% }) %>
                    <% } else { %>
                      <div style="padding:20px;text-align:center;color:var(--t2);font-size:14px;">No reviews yet.</div>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          </section>

        </div><!-- /.content -->
      </main>

      <div id="toast-wrap"></div>

      <!-- Seller navigation (used by quick-card shortcuts) -->
      <nav id="sellerNav" style="display:none" aria-hidden="true">
        <div class="nav-item" data-section="sDash" onclick="nav(this,'sDash')"></div>
        <div class="nav-item" data-section="sMessages" onclick="nav(this,'sMessages')"></div>
        <div class="nav-item" data-section="sProfile" onclick="nav(this,'sProfile')"></div>
      </nav>

      <script>window.INITIAL_SECTION = "<%= (typeof initialSection !== 'undefined' ? initialSection : 'sDash') %>";</script>
      <script src="/js/rating.js"></script>
      <%- include('partials/dashboard-scripts') %>
</body>

</html>